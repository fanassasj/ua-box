ssh_apply_login_profile() {
  local label="$1"
  local root_login="$2"
  local password_auth="$3"
  local backup
  backup="/etc/ssh/sshd_config.ua-box.$(date +%Y%m%d-%H%M%S).bak"


  need_root || return 1
  if [ ! -f /etc/ssh/sshd_config ]; then
    echo "未找到 /etc/ssh/sshd_config。"
    return 1
  fi

  cp /etc/ssh/sshd_config "$backup" || return 1
  if ! ssh_set_global_option /etc/ssh/sshd_config PermitRootLogin "$root_login" ||
     ! ssh_set_global_option /etc/ssh/sshd_config PasswordAuthentication "$password_auth" ||
     ! ssh_set_global_option /etc/ssh/sshd_config PubkeyAuthentication yes; then
    cp "$backup" /etc/ssh/sshd_config
    echo "SSH 配置写入失败，已回滚到: $backup"
    return 1
  fi

  if ! sshd -t; then
    cp "$backup" /etc/ssh/sshd_config
    echo "SSH 配置校验失败，已回滚到: $backup"
    return 1
  fi

  if ! ssh_restart_service; then
    cp "$backup" /etc/ssh/sshd_config
    ssh_restart_service >/dev/null 2>&1 || true
    echo "SSH 重启失败，已回滚到: $backup"
    return 1
  fi

  log_action "$label"
  echo "SSH 配置已更新并重启。备份: $backup"
  if has_cmd sshd; then
    echo "当前生效摘要:"
    sshd -T -C user=root,host=localhost,addr=127.0.0.1 2>/dev/null | grep -E '^(permitrootlogin|passwordauthentication|pubkeyauthentication)' || true
  fi
}

