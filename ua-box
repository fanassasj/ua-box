docker_compose_menu() {
  docker_require || { pause; return; }

  local proj_dirs=()
  local dir

  # 1. 优先从容器 Labels 中直接秒级抓取已被 Docker 记录的 Compose 工作目录，完全免去 find 扫描
  echo "正在从系统容器中自动提取 Compose 项目目录..."
  while IFS= read -r dir; do
    if [ -n "$dir" ] && [ -d "$dir" ]; then
      proj_dirs+=("$dir")
    fi
  done < <(docker ps -a --format '{{.Label "com.docker.compose.project.working_dir"}}' 2>/dev/null | sort -u)

  while true; do
    clear
    echo -e "${gl_kjlan}Docker Compose 项目管理${gl_bai}"
    echo -e "${gl_kjlan}------------------------------------------------------------${gl_bai}"
    
    local idx=1
    if [ ${#proj_dirs[@]} -gt 0 ]; then
      echo "从系统容器运行历史中自动获取的项目："
      for dir in "${proj_dirs[@]}"; do
        printf "%2d)  %-30s (%s)\n" "$idx" "$(basename "$dir")" "$dir"
        idx=$((idx + 1))
      done
    else
      echo "（暂未检测到运行过 Compose 的容器记录）"
    fi
    echo -e "${gl_kjlan}------------------------------------------------------------${gl_bai}"
    echo -e "${gl_kjlan}s.   ${gl_bai}手动扫描未启动的项目目录"
    echo -e "${gl_kjlan}0.   ${gl_bai}返回上级"
    echo -e "${gl_kjlan}------------------------------------------------------------${gl_bai}"
    
    read -r -e -p "请输入项目编号或选择操作: " choice
    [ -z "$choice" ] && continue
    if [ "$choice" = "0" ]; then
      break
    fi

    # 手动扫描
    if [ "$choice" = "s" ] || [ "$choice" = "S" ]; then
      local search_dir="/root"
      echo "默认扫描目录为 /root 和 /home（限深 5 层）。"
      read -r -e -p "请输入你要扫描的目录，直接回车默认: " user_dir
      [ -n "$user_dir" ] && search_dir="$user_dir"

      if [ ! -d "$search_dir" ]; then
        echo "错误: 目录不存在: $search_dir"
        pause
        continue
      fi

      echo "正在扫描 $search_dir 下的 Compose 项目，请稍候..."
      local scanned_files=()
      local f scanned_dir
      while IFS= read -r f; do
        [ -n "$f" ] && scanned_files+=("$f")
      done < <(find "$search_dir" -maxdepth 5 \( -name "docker-compose.yml" -o -name "docker-compose.yaml" -o -name "compose.yml" -o -name "compose.yaml" \) 2>/dev/null)

      # 合并到 proj_dirs 中去重
      local added_count=0
      for f in "${scanned_files[@]}"; do
        scanned_dir="$(dirname "$f")"
        local exists=0
        for d in "${proj_dirs[@]}"; do
          [ "$d" = "$scanned_dir" ] && exists=1 && break
        done
        if [ "$exists" -eq 0 ]; then
          proj_dirs+=("$scanned_dir")
          added_count=$((added_count + 1))
        fi
      done
      echo "扫描完成。新增找到 $added_count 个未运行的项目目录。"
      pause
      continue
    fi

    # 选项编号合法性判断
    if ! printf '%s\n' "$choice" | grep -Eq '^[0-9]+$' || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#proj_dirs[@]} ]; then
      echo "无效选择。"
      pause
      continue
    fi

    local target_dir="${proj_dirs[$((choice - 1))]}"
    docker_compose_project_control "$target_dir"
  done
}

docker_limit_container_logs() {
  need_root || return 1
  mkdir -p /etc/docker
  local daemon_file="/etc/docker/daemon.json"

  echo -e "${gl_kjlan}Docker 容器日志体积限制${gl_bai}"
  echo -e "该操作将限制所有新建/重建的容器日志最大为 50MB，并仅保留最近 3 个文件，彻底杜绝磁盘爆满问题。"
  echo -e "已运行的容器在下次重建(docker rm & docker run)时该配置会生效。"
  echo -e "${gl_kjlan}------------------------${gl_bai}"

  if [ -f "$daemon_file" ]; then
    echo "检测到已存在 daemon.json。正在尝试安全合并限制参数..."
    cp "$daemon_file" "${daemon_file}.ua-box.bak.$(date +%Y%m%d-%H%M%S)"
    
    local success=0
    if has_cmd python3; then
      python3 -c '
import json, sys
try:
    with open(sys.argv[1], "r") as f:
        data = json.load(f)
except Exception:
    data = {}
data["log-driver"] = "json-file"
data["log-opts"] = {"max-size": "50m", "max-file": "3"}
with open(sys.argv[1], "w") as f:
    json.dump(data, f, indent=2)
' "$daemon_file" && success=1
    elif has_cmd jq; then
      local tmp_json
      tmp_json="$(jq '. + {"log-driver": "json-file", "log-opts": {"max-size": "50m", "max-file": "3"}}' "$daemon_file" 2>/dev/null)"
      if [ -n "$tmp_json" ]; then
        echo "$tmp_json" > "$daemon_file"
        success=1
      fi
    fi

    if [ "$success" -eq 1 ]; then
      echo -e "${gl_lv}成功将限制参数安全合并进现有的 daemon.json 中！${gl_bai}"
    else
      echo -e "${gl_huang}警告: 未找到 python3/jq 或合并解析出错。将覆盖写入全新的限制配置。${gl_bai}"
      cat > "$daemon_file" <<'EOF'
{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "50m",
    "max-file": "3"
  }
}
EOF
    fi
  else
    cat > "$daemon_file" <<'EOF'
{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "50m",
    "max-file": "3"
  }
}
EOF
    echo -e "${gl_lv}已创建并写入限制容器日志配置到 /etc/docker/daemon.json${gl_bai}"
  fi

  # 语法校验以防写入乱码导致 docker 启动失败
  local check_rc=0
  if has_cmd python3; then
    python3 -m json.tool "$daemon_file" >/dev/null 2>&1 || check_rc=$?
  elif has_cmd jq; then
    jq . "$daemon_file" >/dev/null 2>&1 || check_rc=$?
  fi

  if [ "$check_rc" -eq 0 ]; then
    echo "正在重启 Docker 以重载配置..."
    if has_cmd systemctl; then
      systemctl restart docker && echo -e "${gl_lv}Docker 服务已重启，日志配置已全局生效！${gl_bai}"
    else
      svc restart docker && echo -e "${gl_lv}Docker 服务已重启，日志配置已全局生效！${gl_bai}"
    fi
  else
    echo -e "${gl_hong}错误: 配置文件 JSON 语法校验失败，已自动恢复备份。${gl_bai}"
    local latest_bak
    latest_bak="$(ls -t "${daemon_file}.ua-box.bak."* 2>/dev/null | head -n 1)"
    if [ -n "$latest_bak" ] && [ -f "$latest_bak" ]; then
      cp "$latest_bak" "$daemon_file" && echo "已恢复先前配置文件。"
    else
      rm -f "$daemon_file"
    fi
  fi
}

