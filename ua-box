system_limit_shutdown_menu() {
  need_root || return 1

  echo -e "${gl_kjlan}限流自动关机${gl_bai}"
  echo "系统每分钟检测网卡总流量，达到阈值后执行 shutdown -h now。"
  system_limit_shutdown_status
  echo -e "${gl_kjlan}------------------------${gl_bai}"
  echo "1. 开启/更新限流自动关机"
  echo "2. 停用限流自动关机"
  echo "0. 返回"
  read -r -e -p "请输入你的选择: " choice

  case "$choice" in
    1)
      local rx_limit tx_limit reset_day
      read -r -e -p "请输入进站流量阈值 GB: " rx_limit
      read -r -e -p "请输入出站流量阈值 GB: " tx_limit
      read -r -e -p "每月几号重置基准，回车默认 1: " reset_day
      reset_day="${reset_day:-1}"
      if ! printf '%s\n' "$rx_limit" | grep -Eq '^[0-9]+$' ||
        ! printf '%s\n' "$tx_limit" | grep -Eq '^[0-9]+$' ||
        ! printf '%s\n' "$reset_day" | grep -Eq '^[0-9]+$' ||
        [ "$reset_day" -lt 1 ] || [ "$reset_day" -gt 31 ]; then
        echo "阈值和日期必须是数字。"
        return 1
      fi
      if confirm_danger "达到流量阈值后自动关机" "RX=${rx_limit}GB TX=${tx_limit}GB reset day=${reset_day}"; then
        mkdir -p "$(dirname "$LIMIT_SHUTDOWN_SCRIPT")"
        cat > "$LIMIT_SHUTDOWN_SCRIPT" <<EOF
#!/usr/bin/env bash
RX_LIMIT_GB=$rx_limit
TX_LIMIT_GB=$tx_limit
RESET_DAY=$reset_day
STATE_FILE="/var/lib/ua-box-limit-shutdown.state"

mkdir -p "\$(dirname "\$STATE_FILE")"
today="\$(date +%d)"
today_full="\$(date +%Y-%m-%d)"
rx_now="\$(awk '\$1 ~ /^[a-zA-Z0-9_.:-]+:\$/ && \$1 !~ /^lo:/ {rx += \$2} END {print rx+0}' /proc/net/dev)"
tx_now="\$(awk '\$1 ~ /^[a-zA-Z0-9_.:-]+:\$/ && \$1 !~ /^lo:/ {tx += \$10} END {print tx+0}' /proc/net/dev)"

# 首次运行：创建基准状态文件
if [ ! -f "\$STATE_FILE" ]; then
  printf 'RX_BASE=%s\nTX_BASE=%s\nLAST_RESET=%s\n' "\$rx_now" "\$tx_now" "\$today_full" > "\$STATE_FILE"
fi

# shellcheck disable=SC1090
. "\$STATE_FILE"

# 每月重置日：仅当天首次执行时更新基准（避免每分钟归零）
if [ "\$today" = "\$(printf "%02d" "\$RESET_DAY")" ] && [ "\${LAST_RESET:-}" != "\$today_full" ]; then
  printf 'RX_BASE=%s\nTX_BASE=%s\nLAST_RESET=%s\n' "\$rx_now" "\$tx_now" "\$today_full" > "\$STATE_FILE"
  # shellcheck disable=SC1090
  . "\$STATE_FILE"
fi

# 检测计数器归零（系统重启导致 /proc/net/dev 重置为小值）
if [ "\$rx_now" -lt "\${RX_BASE:-0}" ] || [ "\$tx_now" -lt "\${TX_BASE:-0}" ]; then
  logger "UA Box limit shutdown: counter reset detected (reboot), updating baseline"
  printf 'RX_BASE=%s\nTX_BASE=%s\nLAST_RESET=%s\n' "\$rx_now" "\$tx_now" "\$today_full" > "\$STATE_FILE"
  # shellcheck disable=SC1090
  . "\$STATE_FILE"
fi

rx_used_gb="\$(( (rx_now - RX_BASE) / 1024 / 1024 / 1024 ))"
tx_used_gb="\$(( (tx_now - TX_BASE) / 1024 / 1024 / 1024 ))"

if [ "\$rx_used_gb" -ge "\$RX_LIMIT_GB" ] || [ "\$tx_used_gb" -ge "\$TX_LIMIT_GB" ]; then
  logger "UA Box limit shutdown: RX=\${rx_used_gb}GB TX=\${tx_used_gb}GB"
  shutdown -h now
fi
EOF
        chmod +x "$LIMIT_SHUTDOWN_SCRIPT"
        (crontab -l 2>/dev/null | grep -vF "$LIMIT_SHUTDOWN_SCRIPT"; echo "* * * * * $LIMIT_SHUTDOWN_SCRIPT") | crontab -
        log_action "enable limit shutdown rx=$rx_limit tx=$tx_limit reset=$reset_day"
        echo "限流自动关机已启用。"
      fi
      ;;
    2)
      if confirm_danger "停用限流自动关机" "$LIMIT_SHUTDOWN_SCRIPT"; then
        crontab -l 2>/dev/null | grep -vF "$LIMIT_SHUTDOWN_SCRIPT" | crontab - 2>/dev/null || true
        rm -f "$LIMIT_SHUTDOWN_SCRIPT"
        log_action "disable limit shutdown"
        echo "限流自动关机已停用。"
      fi
      ;;
    0) return 0 ;;
    *) echo "无效输入" ;;
  esac
}

# 公共函数: 应用 hostname 修改并同步 /etc/hosts
_apply_hostname() {
  local new_hostname="$1"
  local current_hostname="$2"
  if has_cmd hostnamectl; then
    hostnamectl set-hostname "$new_hostname"
  else
    hostname "$new_hostname"
    printf '%s\n' "$new_hostname" > /etc/hostname
  fi
  if grep -q "$current_hostname" /etc/hosts 2>/dev/null; then
    sed -i "s/\b${current_hostname}\b/${new_hostname}/g" /etc/hosts
  fi
  if ! grep -q "$new_hostname" /etc/hosts 2>/dev/null; then
    echo "127.0.1.1 $new_hostname" >> /etc/hosts
  fi
  echo "已同步更新 /etc/hosts。"
}

system_set_hostname() {
  local current_hostname new_hostname
  current_hostname="$(hostname)"
  echo -e "当前 hostname: ${gl_lv}${current_hostname}${gl_bai}"
  read -r -e -p "请输入新的 hostname（直接回车取消）: " new_hostname
  [ -z "$new_hostname" ] && echo "已取消。" && return 0

  # 基础合法性检查：只允许字母、数字、连字符，不能以连字符结尾
  if ! printf '%s' "$new_hostname" | grep -Eq '^[a-zA-Z0-9][a-zA-Z0-9-]{0,62}$' || \
       printf '%s' "$new_hostname" | grep -Eq '\-$'; then
    echo -e "${gl_hong}错误:${gl_bai} hostname 只能包含字母、数字、连字符，且不能以连字符结尾。"
    return 1
  fi

  _apply_hostname "$new_hostname" "$current_hostname"
  log_action "set hostname: $current_hostname -> $new_hostname"
  echo -e "hostname 已修改为: ${gl_lv}${new_hostname}${gl_bai}"
  echo -e "${gl_huang}提示:${gl_bai} 新 hostname 对当前 shell 的提示符立即生效，重新登录后完全生效。"
}

# ── 一键初始化优化 ──────────────────────────────────────────
system_init_optimize() {
  need_root || return 1

  local mem_mb swap_mb
  local do_hostname=n new_hostname="" current_hostname
  local step_ok="${gl_lv}✓${gl_bai}"
  local step_skip="${gl_huang}–${gl_bai}"
  local step_fail="${gl_hong}✗${gl_bai}"

  # ── 采集当前内存与硬盘空间，计算安全的 swap 大小 ──────
  mem_mb="$(free -m | awk '/^Mem:/ {print $2}')"
  if ! printf '%s' "$mem_mb" | grep -Eq '^[0-9]+$' || [ "$mem_mb" -lt 64 ]; then
    mem_mb=1024
  fi
  
  # 获取 / 目录剩余空间 (MB)
  local free_kb free_mb
  free_kb="$(df -k / 2>/dev/null | awk 'NR==2 {print $4}')"
  free_mb=$(( free_kb / 1024 ))
  [ -z "$free_mb" ] || ! printf '%s' "$free_mb" | grep -Eq '^[0-9]+$' && free_mb=0

  swap_mb=$(( mem_mb * 2 ))
  # 限制最大 Swap 建议值不超过 8GB，且必须保留至少 2GB 硬盘空余空间以防爆盘
  if [ "$swap_mb" -gt 8192 ]; then
    swap_mb=8192
  fi
  if [ $(( free_mb - swap_mb )) -lt 2048 ]; then
    swap_mb=$(( free_mb - 2048 ))
  fi
  if [ "$swap_mb" -lt 256 ]; then
    swap_mb=0
  fi

  # ── 要安装的工具包 ───────────────────────────────────────
  local INIT_TOOLS="curl wget sudo socat htop btop iftop unzip tar tmux vim nano git jq ncdu fzf lsof net-tools ca-certificates"

  current_hostname="$(hostname)"

  # ── 打印计划 ────────────────────────────────────────────
  clear
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"
  echo -e "${gl_kjlan}  初始服务器一键优化${gl_bai}"
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"
  echo -e "  将按顺序执行以下步骤："
  echo -e "  ${gl_kjlan}[1]${gl_bai} 系统更新"
  echo -e "  ${gl_kjlan}[2]${gl_bai} 安装常用工具"
  echo -e "        $INIT_TOOLS"
  echo -e "  ${gl_kjlan}[3]${gl_bai} 设置 Swap 为内存的 2 倍 (${swap_mb}MB，当前内存 ${mem_mb}MB)"
  echo -e "  ${gl_kjlan}[4]${gl_bai} 安装 Docker"
  echo -e "  ${gl_kjlan}[5]${gl_bai} 修改 hostname（可选，默认跳过）"
  echo -e "  ${gl_kjlan}[6]${gl_bai} 开启内核网络优化与系统环境调优 (含文件数限制/SSH加速/NTP)"
  echo -e "  ${gl_kjlan}[7]${gl_bai} 默认开启 BBR 拥塞控制"
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"

  # ── 询问是否修改 hostname ────────────────────────────────
  echo -e "当前 hostname: ${gl_lv}${current_hostname}${gl_bai}"
  read -r -e -p "是否修改 hostname？[y/N]: " do_hostname
  do_hostname="${do_hostname:-n}"

  if [ "$do_hostname" = "y" ] || [ "$do_hostname" = "Y" ]; then
    while true; do
      read -r -e -p "请输入新的 hostname（直接回车取消修改）: " new_hostname
      if [ -z "$new_hostname" ]; then
        do_hostname=n
        echo "已跳过修改 hostname。"
        break
      elif printf '%s' "$new_hostname" | grep -Eq '^[a-zA-Z0-9][a-zA-Z0-9-]{0,62}$' && \
           printf '%s' "$new_hostname" | grep -Eq '[a-zA-Z0-9]$'; then
        break
      else
        echo -e "${gl_hong}hostname 格式不合法${gl_bai}，只能包含字母、数字、连字符，且不能以连字符结尾，请重新输入。"
      fi
    done
  fi

  echo ""
  read -r -e -p "确认开始优化？[Y/n]: " confirm_start
  confirm_start="${confirm_start:-y}"
  if [ "$confirm_start" = "n" ] || [ "$confirm_start" = "N" ]; then
    echo "已取消。"
    return 0
  fi

  echo ""
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"

  # ── 结果追踪 ────────────────────────────────────────────
  local r_update=0 r_tools=0 r_swap=0 r_docker=0 r_hostname=0
  local tools_failed="" tools_ok=""

  # ── [1] 系统更新 ─────────────────────────────────────────
  echo -e "\n${gl_kjlan}[1/5] 系统更新...${gl_bai}"
  if system_update; then
    r_update=1
    echo -e "$step_ok 系统更新完成"
  else
    echo -e "$step_fail 系统更新失败"
  fi

  # ── [2] 安装常用工具 ─────────────────────────────────────
  echo -e "\n${gl_kjlan}[2/5] 安装常用工具...${gl_bai}"
  local pm tool_pkg _batch_ok TOOLS_TO_INSTALL=""
  pm="$(pkg_manager)"

  # 1. 预先检测哪些工具尚未安装
  for tool_pkg in $INIT_TOOLS; do
    if ! is_pkg_installed "$tool_pkg"; then
      TOOLS_TO_INSTALL="$TOOLS_TO_INSTALL $tool_pkg"
    else
      tools_ok="$tools_ok $tool_pkg"
    fi
  done

  # 2. 执行安装（仅针对未安装的工具）
  if [ -z "$TOOLS_TO_INSTALL" ]; then
    r_tools=1
    echo -e "$step_ok 所有常用工具已处于最新状态，无需安装"
  else
    echo "  正在安装未就绪的工具: $TOOLS_TO_INSTALL ..."
    # shellcheck disable=SC2086
    case "$pm" in
      apt)    apt install -y $TOOLS_TO_INSTALL > /dev/null 2>&1 ; _batch_ok=$? ; touch /tmp/.ua-apt-updated 2>/dev/null || true ;;
      dnf)    dnf install -y $TOOLS_TO_INSTALL > /dev/null 2>&1 ; _batch_ok=$? ;;
      yum)    yum install -y $TOOLS_TO_INSTALL > /dev/null 2>&1 ; _batch_ok=$? ;;
      apk)    apk add $TOOLS_TO_INSTALL > /dev/null 2>&1       ; _batch_ok=$? ;;
      pacman) pacman -S --noconfirm $TOOLS_TO_INSTALL > /dev/null 2>&1 ; _batch_ok=$? ;;
      zypper) zypper install -y $TOOLS_TO_INSTALL > /dev/null 2>&1     ; _batch_ok=$? ;;
      *)      _batch_ok=1 ;;
    esac

    # 逐包最终校验：如果批量安装失败，尝试针对失败的包进行单独重试
    for tool_pkg in $TOOLS_TO_INSTALL; do
      if is_pkg_installed "$tool_pkg"; then
        tools_ok="$tools_ok $tool_pkg"
      else
        local _retry_ok=0
        case "$pm" in
          apt)    apt install -y "$tool_pkg" > /dev/null 2>&1 && _retry_ok=1 ;;
          dnf)    dnf install -y "$tool_pkg" > /dev/null 2>&1 && _retry_ok=1 ;;
          yum)    yum install -y "$tool_pkg" > /dev/null 2>&1 && _retry_ok=1 ;;
          apk)    apk add "$tool_pkg" > /dev/null 2>&1        && _retry_ok=1 ;;
          pacman) pacman -S --noconfirm "$tool_pkg" > /dev/null 2>&1 && _retry_ok=1 ;;
          zypper) zypper install -y "$tool_pkg" > /dev/null 2>&1     && _retry_ok=1 ;;
        esac
        if is_pkg_installed "$tool_pkg" || [ "$_retry_ok" -eq 1 ]; then
          tools_ok="$tools_ok $tool_pkg"
        else
          tools_failed="$tools_failed $tool_pkg"
        fi
      fi
    done

    if [ -z "$tools_failed" ]; then
      r_tools=1
      echo -e "$step_ok 常用工具安装完成"
    else
      echo -e "$step_fail 部分常用工具安装失败"
    fi
  fi
  log_action "init_optimize install tools: ok=[$tools_ok] fail=[$tools_failed]"

  # ── [3] 设置 Swap ────────────────────────────────────────
  if [ "$swap_mb" -eq 0 ]; then
    echo -e "\n${gl_kjlan}[3/5] 设置 Swap...${gl_bai}"
    echo -e "$step_skip 磁盘剩余空间不足（当前剩余 ${free_mb}MB，安全限制需留 2GB），已跳过 Swap 创建。"
    r_swap=2
  else
    echo -e "\n${gl_kjlan}[3/5] 设置 Swap 为 ${swap_mb}MB...${gl_bai}"
    local swap_result=0
    (
      swapoff /swapfile 2>/dev/null || true
      sed -i '\|/swapfile swap swap|d' /etc/fstab 2>/dev/null || true
      rm -f /swapfile
      if has_cmd fallocate; then
        fallocate -l "${swap_mb}M" /swapfile 2>/dev/null || \
          dd if=/dev/zero of=/swapfile bs=1M count="$swap_mb" status=none
      else
        dd if=/dev/zero of=/swapfile bs=1M count="$swap_mb" status=none
      fi
      chmod 600 /swapfile
      mkswap /swapfile > /dev/null
      swapon /swapfile
      grep -q '/swapfile swap swap' /etc/fstab || \
        echo "/swapfile swap swap defaults 0 0" >> /etc/fstab
    ) && swap_result=1
    if [ "$swap_result" -eq 1 ]; then
      r_swap=1
      log_action "init_optimize swap ${swap_mb}MB"
      echo -e "$step_ok Swap 已设置为 ${swap_mb}MB"
    else
      echo -e "$step_fail Swap 设置失败"
    fi
  fi

  # ── [4] 安装 Docker ──────────────────────────────────────
  echo -e "\n${gl_kjlan}[4/5] 安装 Docker...${gl_bai}"
  if install_docker; then
    r_docker=1
  fi

  # ── [5] 修改 hostname ────────────────────────────────────
  echo -e "\n${gl_kjlan}[5/7] 修改 hostname...${gl_bai}"
  if [ "$do_hostname" = "y" ] || [ "$do_hostname" = "Y" ]; then
    _apply_hostname "$new_hostname" "$current_hostname"
    log_action "init_optimize hostname: $current_hostname -> $new_hostname"
    r_hostname=1
    echo -e "$step_ok hostname 已修改为 ${gl_lv}${new_hostname}${gl_bai}"
  else
    echo -e "$step_skip hostname 已跳过（保持 ${current_hostname}）"
  fi

  # ── [6] 系统环境与 TCP 协议栈高级优化 ──────────────────
  echo -e "\n${gl_kjlan}[6/7] 开启网络内核协议栈与系统环境调优...${gl_bai}"
  local r_tcptune=0
  local has_changes=0
  (
    local _local_changes=0
    # 1. TCP 协议栈调优
    local sysctl_tcp_conf="/etc/sysctl.d/99-ua-tcp-tune.conf"
    local target_tcp_conf="# UA Box TCP High Performance Tuning
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
net.ipv4.tcp_keepalive_time = 600
net.ipv4.tcp_max_syn_backlog = 16384
net.core.netdev_max_backlog = 25000
net.ipv4.tcp_max_tw_buckets = 5000
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_rmem = 4096 87380 67108864
net.ipv4.tcp_wmem = 4096 65536 67108864
net.core.somaxconn = 4096"
    
    local tcp_needs_write=1
    if [ -f "$sysctl_tcp_conf" ]; then
      local cur_strip target_strip
      cur_strip="$(grep -v '^#' "$sysctl_tcp_conf" 2>/dev/null | tr -d '[[:space:]]')"
      target_strip="$(echo "$target_tcp_conf" | grep -v '^#' | tr -d '[[:space:]]')"
      if [ "$cur_strip" = "$target_strip" ]; then
        tcp_needs_write=0
      fi
    fi

    if [ "$tcp_needs_write" -eq 1 ]; then
      echo "$target_tcp_conf" > "$sysctl_tcp_conf"
      sysctl -p "$sysctl_tcp_conf" >/dev/null 2>&1 || sysctl --system >/dev/null 2>&1
      _local_changes=1
    fi

    # 2. 提升文件描述符上限 (Ulimit nofile)
    if ! grep -q "soft nofile 65535" /etc/security/limits.conf 2>/dev/null; then
      cat >> /etc/security/limits.conf << 'EOF'
* soft nofile 65535
* hard nofile 65535
root soft nofile 65535
root hard nofile 65535
EOF
      _local_changes=1
    fi
    
    if ! grep -q "DefaultLimitNOFILE=65535" /etc/systemd/system.conf 2>/dev/null; then
      sed -i 's/^#\?DefaultLimitNOFILE.*/DefaultLimitNOFILE=65535/g' /etc/systemd/system.conf 2>/dev/null || true
      _local_changes=1
    fi
    if ! grep -q "DefaultLimitNOFILE=65535" /etc/systemd/user.conf 2>/dev/null; then
      sed -i 's/^#\?DefaultLimitNOFILE.*/DefaultLimitNOFILE=65535/g' /etc/systemd/user.conf 2>/dev/null || true
      _local_changes=1
    fi

    # 3. 提升 SSH 登录速度 (UseDNS / GSSAPI)
    local ssh_needs_update=0
    if [ -f /etc/ssh/sshd_config ]; then
      if ! grep -Eq '^UseDNS[[:space:]]+no' /etc/ssh/sshd_config || ! grep -Eq '^GSSAPIAuthentication[[:space:]]+no' /etc/ssh/sshd_config; then
        ssh_needs_update=1
      fi
    fi

    if [ "$ssh_needs_update" -eq 1 ]; then
      sed -i -e 's/^#\?UseDNS.*/UseDNS no/g' -e 's/^#\?GSSAPIAuthentication.*/GSSAPIAuthentication no/g' /etc/ssh/sshd_config
      systemctl restart ssh sshd 2>/dev/null || service ssh restart 2>/dev/null || service sshd restart 2>/dev/null || true
      _local_changes=1
    fi

    # 4. 自动开启 NTP 时间同步
    timedatectl set-ntp true 2>/dev/null || true
    
    echo "$_local_changes" > /tmp/.ua-tcptune-has-changes
  ) && r_tcptune=1
  
  if [ "$r_tcptune" -eq 1 ]; then
    local _ch
    _ch="$(cat /tmp/.ua-tcptune-has-changes 2>/dev/null)"
    rm -f /tmp/.ua-tcptune-has-changes
    if [ "$_ch" = "1" ]; then
      echo -e "$step_ok 系统环境与 TCP 调优配置已成功应用"
    else
      echo -e "$step_skip 系统环境与 TCP 配置已是最新状态，无需重复调优"
    fi
  else
    echo -e "$step_fail 系统环境与 TCP 调优配置应用失败"
  fi

  # ── [7] 默认开启 BBR 拥塞控制 ─────────────────────────────
  echo -e "\n${gl_kjlan}[7/7] 默认开启 BBR 拥塞控制...${gl_bai}"
  local r_bbr=0
  local virt_type
  virt_type="$(get_virt)"
  if [ "$virt_type" = "OPENVZ" ] || [ "$virt_type" = "LXC" ]; then
    echo -e "$step_skip 架构为 ${virt_type}，不支持开启 BBR"
  else
    local sysctl_conf="/etc/sysctl.d/99-ua-bbr.conf"
    local bbr_active=0
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q bbr; then
      if [ -f "$sysctl_conf" ] && grep -q "tcp_congestion_control=bbr" "$sysctl_conf" 2>/dev/null; then
        bbr_active=1
      fi
    fi

    if [ "$bbr_active" -eq 1 ]; then
      r_bbr=1
      echo -e "$step_skip BBR 拥塞控制已启用，无需重复配置"
    else
      local kver major minor
      kver="$(uname -r)"
      major="$(printf '%s' "$kver" | cut -d. -f1)"
      minor="$(printf '%s' "$kver" | cut -d. -f2)"
      if [ "$major" -lt 4 ] || { [ "$major" -eq 4 ] && [ "$minor" -lt 9 ]; }; then
        echo -e "$step_fail 当前内核 $kver 不支持 BBR（需要 >= 4.9）"
      else
        modprobe tcp_bbr 2>/dev/null || true
        cat > "$sysctl_conf" <<'SYSCTL'
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
SYSCTL
        if sysctl -p "$sysctl_conf" >/dev/null 2>&1 || sysctl --system >/dev/null 2>&1; then
          r_bbr=1
          echo -e "$step_ok BBR 拥塞控制已成功开启"
        else
          echo -e "$step_fail BBR 开启失败"
        fi
      fi
    fi
  fi

  # ── 汇总报告 ─────────────────────────────────────────────
  echo ""
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"
  echo -e "${gl_kjlan}  优化结果汇总${gl_bai}"
  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"

  # 系统更新
  [ "$r_update" -eq 1 ] && echo -e "  $step_ok 系统更新" || echo -e "  $step_fail 系统更新"

  # 工具安装
  if [ "$r_tools" -eq 1 ]; then
    echo -e "  $step_ok 常用工具安装"
  else
    echo -e "  $step_fail 常用工具（以下包安装失败）:${gl_hong}$tools_failed${gl_bai}"
  fi
  if [ -n "$tools_ok" ]; then
    echo -e "        已安装:${gl_lv}$tools_ok${gl_bai}"
  fi

  # Swap
  if [ "$r_swap" -eq 1 ]; then
    local cur_swap
    cur_swap="$(free -m | awk '/^Swap:/ {print $2}')MB"
    echo -e "  $step_ok Swap 设置为 ${swap_mb}MB（当前: $cur_swap）"
  elif [ "$r_swap" -eq 2 ]; then
    echo -e "  $step_skip Swap 设置已跳过（磁盘空间不足）"
  else
    echo -e "  $step_fail Swap 设置"
  fi

  # Docker
  if [ "$r_docker" -eq 1 ]; then
    echo -e "  $step_ok Docker $(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')"
  else
    echo -e "  $step_fail Docker 安装"
  fi

  # hostname
  if [ "$do_hostname" = "y" ] || [ "$do_hostname" = "Y" ]; then
    [ "$r_hostname" -eq 1 ] \
      && echo -e "  $step_ok hostname → ${gl_lv}${new_hostname}${gl_bai}" \
      || echo -e "  $step_fail hostname 修改"
  else
    echo -e "  $step_skip hostname 未修改（${current_hostname}）"
  fi

  # TCP 协议栈调优
  [ "$r_tcptune" -eq 1 ] && echo -e "  $step_ok TCP/文件描述符/SSH加速/时间同步优化已生效" || echo -e "  $step_fail 系统环境与网络优化"

  # BBR 拥塞控制
  if [ "$r_bbr" -eq 1 ]; then
    echo -e "  $step_ok BBR 拥塞控制已开启"
  else
    if [ "$virt_type" = "OPENVZ" ] || [ "$virt_type" = "LXC" ]; then
      echo -e "  $step_skip BBR 拥塞控制（容器虚拟化暂不支持）"
    else
      echo -e "  $step_fail BBR 拥塞控制（内核版本过低或配置加载失败）"
    fi
  fi

  echo -e "${gl_kjlan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${gl_bai}"
  log_action "init_optimize done"
}
