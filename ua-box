rclone_mount_systemd() {
  need_root || return 1
  rclone_require || return 1

  local remote_path mount_point extra config_file rclone_path service_name service_file
  read -r -e -p "请输入远程路径，如 remote:path : " remote_path
  read -r -e -p "请输入本地挂载点: " mount_point
  read -r -e -p "额外参数，回车使用默认: " extra
  [ -z "$extra" ] && extra="$DEFAULT_RCLONE_MOUNT_ARGS"

  if [ -z "$remote_path" ] || [ -z "$mount_point" ]; then
    echo "远程路径和本地挂载点不能为空。"
    return 1
  fi

  # 转换绝对路径
  mkdir -p "$mount_point"
  mount_point="$(readlink -f "$mount_point" 2>/dev/null || echo "$mount_point")"

  # 生成合法的服务名后缀
  service_name="$(echo "$mount_point" | sed 's|^/||; s|/|-|g; s|[^a-zA-Z0-9-]||g')"
  [ -z "$service_name" ] && service_name="default"
  service_file="/etc/systemd/system/rclone-mount-${service_name}.service"

  config_file="$(rclone_config_file_path)"
  rclone_path="$(command -v rclone 2>/dev/null || echo "/usr/bin/rclone")"

  # 写入服务文件：限制 5分钟(300s)内最多重试 5 次，规避无限循环重启
  cat > "$service_file" <<EOF
[Unit]
Description=RClone Mount Service for ${service_name}
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
ExecStart=${rclone_path} mount "${remote_path}" "${mount_point}" --config="${config_file}" ${extra}
ExecStop=/bin/umount -l "${mount_point}"
Restart=on-failure
RestartSec=15

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable "rclone-mount-${service_name}.service"
  systemctl restart "rclone-mount-${service_name}.service"

  sleep 1.5
  if systemctl is-active --quiet "rclone-mount-${service_name}.service"; then
    log_action "rclone systemd mount configured: ${service_name} -> ${mount_point}"
    echo -e "${gl_lv}✓ RClone 开机自启守护服务已成功配置并启动！${gl_bai}"
    echo "服务名称: rclone-mount-${service_name}.service"
    echo "挂载点: $mount_point"
  else
    echo -e "${gl_hong}✗ 服务启动失败！${gl_bai} 请执行以下命令查看日志排查原因："
    echo "journalctl -u rclone-mount-${service_name}.service -n 50 --no-pager"
  fi
}

rclone_unmount_point() {
  local mount_point service_name service_file
  read -r -e -p "请输入本地挂载点: " mount_point
  [ -z "$mount_point" ] && echo "挂载点不能为空。" && return 1

  mount_point="$(readlink -f "$mount_point" 2>/dev/null || echo "$mount_point")"
  service_name="$(echo "$mount_point" | sed 's|^/||; s|/|-|g; s|[^a-zA-Z0-9-]||g')"
  [ -z "$service_name" ] && service_name="default"
  service_file="/etc/systemd/system/rclone-mount-${service_name}.service"

  if [ -f "$service_file" ]; then
    echo "检测到该挂载点由 Systemd 守护服务运行，正在卸载并删除该开机自启服务..."
    systemctl disable --now "rclone-mount-${service_name}.service" 2>/dev/null || true
    rm -f "$service_file"
    systemctl daemon-reload
    log_action "rclone systemd mount removed: ${service_name}"
    echo "Systemd 守护服务已被清除。"
  fi

  if has_cmd fusermount; then
    fusermount -uz "$mount_point" 2>/dev/null || umount -l "$mount_point" 2>/dev/null || true
  elif has_cmd fusermount3; then
    fusermount3 -uz "$mount_point" 2>/dev/null || umount -l "$mount_point" 2>/dev/null || true
  else
    umount -l "$mount_point" 2>/dev/null || true
  fi
  echo "挂载点卸载操作已完成。"
}

