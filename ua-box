ignore_var_for_kind() {
  case "$1" in
    container|containers|docker|容器) echo "UA_IGNORE_CONTAINERS" ;;
    service|services|svc|服务) echo "UA_IGNORE_SERVICES" ;;
    rclone|remote|remotes|远程盘) echo "UA_IGNORE_RCLONE_REMOTES" ;;
    *) return 1 ;;
  esac
}

ignore_label_for_kind() {
  case "$1" in
    container|containers|docker|容器) echo "容器" ;;
    service|services|svc|服务) echo "服务" ;;
    rclone|remote|remotes|远程盘) echo "rclone remote" ;;
    *) return 1 ;;
  esac
}

ignore_current_value() {
  case "$1" in
    UA_IGNORE_CONTAINERS) printf '%s\n' "$UA_IGNORE_CONTAINERS" ;;
    UA_IGNORE_SERVICES) printf '%s\n' "$UA_IGNORE_SERVICES" ;;
    UA_IGNORE_RCLONE_REMOTES) printf '%s\n' "$UA_IGNORE_RCLONE_REMOTES" ;;
    *) return 1 ;;
  esac
}

ua_ignore_show() {
  echo -e "${gl_kjlan}异常忽略列表${gl_bai}"
  echo -e "${gl_kjlan}------------------------${gl_bai}"
  echo "容器: ${UA_IGNORE_CONTAINERS:-无}"
  echo "服务: ${UA_IGNORE_SERVICES:-无}"
  echo "rclone remote: ${UA_IGNORE_RCLONE_REMOTES:-无}"
}

ua_ignore_add() {
  local kind="$1"
  shift

  local var label current next normalized item
  var="$(ignore_var_for_kind "$kind")" || { echo "未知类型: $kind"; return 1; }
  label="$(ignore_label_for_kind "$kind")"
  if [ "$#" -eq 0 ]; then
    echo "未提供要忽略的${label}名称。"
    return 1
  fi

  current="$(ignore_current_value "$var")"
  for item in "$@"; do
    normalized="${item%:}"
    next="$(list_add_words "$current" "$normalized")"
    current="$next"
  done
  config_set_var "$var" "$current"
  log_action "ignore add $kind $*"
  echo "已加入忽略列表: $label -> $*"
}

ua_ignore_remove() {
  local kind="$1"
  shift

  local var label current next normalized items
  var="$(ignore_var_for_kind "$kind")" || { echo "未知类型: $kind"; return 1; }
  label="$(ignore_label_for_kind "$kind")"
  if [ "$#" -eq 0 ]; then
    echo "未提供要取消忽略的${label}名称。"
    return 1
  fi

  current="$(ignore_current_value "$var")"
  items=""
  for item in "$@"; do
    normalized="${item%:}"
    items="${items:+$items }$normalized"
  done
  # shellcheck disable=SC2086
  next="$(list_remove_words "$current" $items)"
  config_set_var "$var" "$next"
  log_action "ignore remove $kind $*"
  echo "已取消忽略: $label -> $*"
}

ua_ignore_current() {
  local yes="$1"
  local bad_containers inactive_services failed_remotes answer

  bad_containers="$(collect_bad_containers | tr '\n' ' ')"
  inactive_services="$(collect_inactive_services | tr '\n' ' ')"
  failed_remotes="$(collect_failed_rclone_remotes | tr '\n' ' ')"

  if [ -z "$bad_containers$inactive_services$failed_remotes" ]; then
    echo "当前没有可加入忽略列表的异常项。"
    return 0
  fi

  echo -e "${gl_kjlan}将加入忽略列表的当前异常项${gl_bai}"
  [ -n "$bad_containers" ] && echo "容器: $bad_containers"
  [ -n "$inactive_services" ] && echo "服务: $inactive_services"
  [ -n "$failed_remotes" ] && echo "rclone remote: $failed_remotes"

  if [ "$yes" != "-y" ] && [ "$yes" != "--yes" ]; then
    read -r -p "确认写入忽略列表？输入 y/yes 继续: " answer
    case "$answer" in
      y|Y|yes|YES) ;;
      *) echo "已取消。"; return 1 ;;
    esac
  fi

  # shellcheck disable=SC2086
  [ -n "$bad_containers" ] && config_set_var "UA_IGNORE_CONTAINERS" "$(list_add_words "$UA_IGNORE_CONTAINERS" $bad_containers)"
  # shellcheck disable=SC2086
  [ -n "$inactive_services" ] && config_set_var "UA_IGNORE_SERVICES" "$(list_add_words "$UA_IGNORE_SERVICES" $inactive_services)"
  # shellcheck disable=SC2086
  [ -n "$failed_remotes" ] && config_set_var "UA_IGNORE_RCLONE_REMOTES" "$(list_add_words "$UA_IGNORE_RCLONE_REMOTES" $failed_remotes)"
  log_action "ignore current"
  echo "已写入忽略列表。"
}

ua_ignore_cli() {
  local action="$1"
  shift || true

  case "$action" in
    ""|menu|管理)
      ua_ignore_menu
      ;;
    list|ls|show|列表)
      ua_ignore_show
      ;;
    current|now|当前)
      ua_ignore_current "$1"
      ;;
    add)
      ua_ignore_add "$@"
      ;;
    remove|rm|del|delete)
      ua_ignore_remove "$@"
      ;;
    container|containers|docker|service|services|svc|rclone|remote|remotes|容器|服务|远程盘)
      ua_ignore_add "$action" "$@"
      ;;
    *)
      echo "用法:"
      echo "  ua ignore list"
      echo "  ua ignore current"
      echo "  ua ignore container <name...>"
      echo "  ua ignore service <name...>"
      echo "  ua ignore rclone <remote...>"
      echo "  ua unignore rclone <remote...>"
      return 1
      ;;
  esac
}

ua_unignore_cli() {
  local action="$1"
  shift || true

  case "$action" in
    container|containers|docker|service|services|svc|rclone|remote|remotes|容器|服务|远程盘)
      ua_ignore_remove "$action" "$@"
      ;;
    *)
      ua_ignore_remove "$action" "$@"
      ;;
  esac
}

