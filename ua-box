}

rclone_require() {
  if ! has_cmd rclone; then
    echo "未找到 rclone，请先安装 rclone。"
    return 1
  fi
}

rclone_config_file_path() {
  rclone config file 2>/dev/null | awk 'NF {line=$0} END {print line}'
}

rclone_remote_summary() {
  rclone_require || return 1

  local config_file
  config_file="$(rclone_config_file_path)"

  echo -e "${gl_kjlan}当前 remotes${gl_bai}"
  if [ -z "$config_file" ] || [ ! -r "$config_file" ]; then
    echo "未找到可读取的 rclone 配置文件。"
    return 0
  fi

  awk '
    function flush() {
      if (name != "") {
        if (type == "") type = "-";
        printf "%-20s %-14s\n", name, type;
      }
    }
    /^\[[^]]+\]$/ {
      flush();
      name = substr($0, 2, length($0)-2);
      type = "";
      next;
    }
    /^[[:space:]]*type[[:space:]]*=/ {
      type = $0;
      sub(/^[^=]*=[[:space:]]*/, "", type);
    }
    END { flush(); }
  ' "$config_file" | awk 'BEGIN {printf "%-20s %-14s\n%-20s %-14s\n", "Name", "Type", "====", "===="} {print}'
}

rclone_config_check() {
  rclone_require || return 1

  local config_file remote_count mount_count check_timeout result_file
  config_file="$(rclone_config_file_path)"
  remote_count="$(rclone listremotes 2>/dev/null | wc -l)"
  mount_count="$(pgrep -af "rclone mount" 2>/dev/null | wc -l)"
  check_timeout="${RCLONE_CHECK_TIMEOUT:-5}"
  result_file="$UA_BOX_TMP_DIR/ua-rclone-check.$$"

  echo -e "${gl_kjlan}rclone 配置检测${gl_bai}"
  echo -e "${gl_kjlan}------------------------${gl_bai}"
  rclone version | head -n 1
  echo "配置文件: ${config_file:-未找到}"
  echo "远程盘数量: $remote_count"
  echo "挂载进程数: $mount_count"
  echo "连接测试超时: ${check_timeout}s/remote"
  echo -e "${gl_kjlan}------------------------${gl_bai}"

  if [ -z "$config_file" ] || [ ! -r "$config_file" ]; then
    echo "配置文件不可读取。"
    return 1
  fi

  echo "正在逐个测试 remote 连接..."
  : > "$result_file"
  while IFS= read -r remote; do
    [ -z "$remote" ] && continue
    printf "测试 %-20s ... " "$remote"
    local output rc status
    if has_cmd timeout; then
      output="$(timeout "$check_timeout" rclone lsd "${remote}:" 2>&1 >/dev/null)"
      rc=$?
      [ "$rc" -eq 124 ] && status="timeout" || status="$([ "$rc" -eq 0 ] && echo ok || echo fail)"
    else
      output="$(rclone lsd "${remote}:" 2>&1 >/dev/null)"
      rc=$?
      status="$([ "$rc" -eq 0 ] && echo ok || echo fail)"
    fi
    printf "%s\n" "$status"
    printf '%s\t%s\t%s\n' "$remote" "$status" "$(printf '%s' "$output" | tr '\t\r\n' '   ' | cut -c1-90)" >> "$result_file"
  done < <(rclone listremotes 2>/dev/null | sed 's/:$//')

  echo -e "${gl_kjlan}------------------------${gl_bai}"
  printf "%-18s %-10s %-16s %-16s %-10s %-32s\n" "Name" "Type" "Auth" "Scope/Root" "Connect" "Message"
  awk -v result_file="$result_file" '
    BEGIN {
      while ((getline line < result_file) > 0) {
        split(line, parts, "\t");
        connect[parts[1]] = parts[2];
        message[parts[1]] = parts[3];
      }
    }
    function flush() {
      if (name == "") return;
      if (type == "") type = "-";
      auth = "-";
      if (service_account_file != "" || service_account_file_path != "") auth = "service-account";
      else if (token == "yes") auth = "oauth-token";
      else if (user != "") auth = "user-pass";

      scope_root = "-";
      if (team_drive != "") scope_root = "team_drive";
      else if (root_folder_id != "") scope_root = "root_folder";
      else if (scope != "") scope_root = scope;

      status = connect[name];
      if (status == "") status = "not-tested";
      msg = message[name];
      if (type == "-") {
        status = "no-type";
        msg = "missing type";
      }
      printf "%-18s %-10s %-16s %-16s %-10s %-32s\n", name, type, auth, scope_root, status, msg;
    }
    /^\[[^]]+\]$/ {
      flush();
      name = substr($0, 2, length($0)-2);
      type = scope = team_drive = root_folder_id = service_account_file = service_account_file_path = user = "";
      token = "no";
      next;
    }
    /^[[:space:]]*type[[:space:]]*=/ { type = $0; sub(/^[^=]*=[[:space:]]*/, "", type); next; }
    /^[[:space:]]*scope[[:space:]]*=/ { scope = $0; sub(/^[^=]*=[[:space:]]*/, "", scope); next; }
    /^[[:space:]]*team_drive[[:space:]]*=/ { team_drive = $0; sub(/^[^=]*=[[:space:]]*/, "", team_drive); next; }
    /^[[:space:]]*root_folder_id[[:space:]]*=/ { root_folder_id = $0; sub(/^[^=]*=[[:space:]]*/, "", root_folder_id); next; }
    /^[[:space:]]*service_account_file[[:space:]]*=/ { service_account_file = $0; sub(/^[^=]*=[[:space:]]*/, "", service_account_file); next; }
    /^[[:space:]]*service_account_file_path[[:space:]]*=/ { service_account_file_path = $0; sub(/^[^=]*=[[:space:]]*/, "", service_account_file_path); next; }
    /^[[:space:]]*user[[:space:]]*=/ { user = "yes"; next; }
    /^[[:space:]]*token[[:space:]]*=/ { token = "yes"; next; }
    END { flush(); }
  ' "$config_file"
  rm -f "$result_file"

  echo -e "${gl_kjlan}------------------------${gl_bai}"
  echo "说明: 已先进行连接测试，再显示安全摘要；不显示 token、密码、client_secret。"
}

rclone_normalize_path() {
  local path="$1"

  if [ -z "$path" ]; then
    return 1
  fi

  if printf '%s\n' "$path" | grep -q ':'; then
    printf '%s\n' "$path"
    return 0
  fi

  if rclone listremotes 2>/dev/null | sed 's/:$//' | grep -Fxq "$path"; then
    printf '%s:\n' "$path"
  else
    printf '%s\n' "$path"
  fi
}

rclone_choose_remote_lsd() {
