docker_container_all_action() {
  local action="$1"

  case "$action" in
    start|rm)
      if [ -z "$(docker ps -a -q 2>/dev/null)" ]; then
        echo "没有可操作的容器。"; return 0
      fi
      ;;
    stop|restart)
      if [ -z "$(docker ps -q 2>/dev/null)" ]; then
        echo "没有可操作的容器。"; return 0
      fi
      ;;
    *) return 1 ;;
  esac

  log_action "docker $action all containers"
  case "$action" in
    rm)      docker ps -a -q | xargs -r docker rm -f ;;
    start)   docker ps -a -q | xargs -r docker start ;;
    stop)    docker ps -q    | xargs -r docker stop ;;
    restart) docker ps -q    | xargs -r docker restart ;;
  esac
}

