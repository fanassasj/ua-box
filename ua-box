get_compose_projects_summary() {
  has_cmd docker || return 0
  docker info >/dev/null 2>&1 || return 0

  local ps_out
  ps_out="$(docker ps -a --format '{{.Names}}\t{{.Label "com.docker.compose.project"}}\t{{.State.Running}}' 2>/dev/null)"
  if [ -z "$ps_out" ]; then
    echo "-"
    return 0
  fi

  printf '%s\n' "$ps_out" | awk -F'\t' '
    $2 != "" {
      proj=$2
      total[proj]++
      if ($3 == "true") running[proj]++
    }
    END {
      count = 0
      for (p in total) {
        run_count = running[p] ? running[p] : 0
        printf "%s (%d/%d %s) | ", p, run_count, total[p], (run_count == total[p] ? "运行" : "部分停止")
        count++
      }
      if (count == 0) printf "-"
    }
  ' | sed 's/ | $//'
}

collect_bad_containers() {
  local container_name container_status

  has_cmd docker || return 0
  docker info >/dev/null 2>&1 || return 0
  while IFS=$'\t' read -r container_name container_status; do
    [ -z "$container_name" ] && continue
    list_has_word "$container_name" "$UA_IGNORE_CONTAINERS" && continue
    case "$container_status" in
      Up*) ;;
      *) printf '%s\n' "$container_name" ;;
    esac
  done < <(docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null)
}

collect_inactive_services() {
  local svc _monitor_svcs

  has_cmd systemctl || return 0
  _monitor_svcs="${UA_MONITOR_SERVICES:-caddy}"
  # shellcheck disable=SC2086
  for svc in $_monitor_svcs; do
    list_has_word "$svc" "$UA_IGNORE_SERVICES" && continue
    if systemctl list-unit-files "${svc}.service" --no-legend 2>/dev/null | grep -q . &&
      ! systemctl is-active --quiet "$svc" 2>/dev/null; then
      printf '%s\n' "$svc"
    fi
  done
}

collect_failed_rclone_remotes() {
  local check_timeout remote rc

  has_cmd rclone || return 0
  check_timeout="${RCLONE_STATUS_CHECK_TIMEOUT:-${RCLONE_CHECK_TIMEOUT:-5}}"
  while IFS= read -r remote; do
    [ -z "$remote" ] && continue
    list_has_word "$remote" "$UA_IGNORE_RCLONE_REMOTES" && continue
    if has_cmd timeout; then
      timeout "$check_timeout" rclone lsd "${remote}:" >/dev/null 2>&1
      rc=$?
    else
      rclone lsd "${remote}:" >/dev/null 2>&1
      rc=$?
    fi
    [ "$rc" -ne 0 ] && printf '%s\n' "$remote"
  done < <(rclone listremotes 2>/dev/null | sed 's/:$//')
}

ua_abnormal_summary() {
  local found cpu_pct mem_pct disk_pct disk_warn disk_crit load_avg load_int cores bad_containers check_timeout failed_remotes remote rc output status svc
  local container_name container_status

  found=0
  check_timeout="${RCLONE_STATUS_CHECK_TIMEOUT:-${RCLONE_CHECK_TIMEOUT:-5}}"
  disk_warn="${UA_STATUS_DISK_WARN:-80}"
  disk_crit="${UA_STATUS_DISK_CRIT:-90}"
  printf '%s\n' "$disk_warn" | grep -Eq '^[0-9]+$' || disk_warn=80
  printf '%s\n' "$disk_crit" | grep -Eq '^[0-9]+$' || disk_crit=90

  echo -e "${gl_kjlan}异常汇总${gl_bai}"

  cpu_pct="$(cpu_usage 2>/dev/null || echo 0)"
  mem_pct="$(free | awk '/^Mem:/ {printf "%.0f", $3*100/$2}' 2>/dev/null)"
  disk_pct="$(df -P / | awk 'NR==2 {gsub("%","",$5); print $5}' 2>/dev/null)"
  load_avg="$(awk '{print $1}' /proc/loadavg 2>/dev/null)"
  cores="$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc 2>/dev/null || echo 1)"

  if printf '%s\n' "$cpu_pct" | grep -Eq '^[0-9]+$' && [ "$cpu_pct" -ge 80 ]; then
    echo "- CPU 占用高: ${cpu_pct}%"
    echo "  建议: 使用 top/htop 查看高占用进程，必要时重启异常服务。"
    found=1
  fi
  if printf '%s\n' "$mem_pct" | grep -Eq '^[0-9]+$' && [ "$mem_pct" -ge 85 ]; then
    echo "- 内存占用高: ${mem_pct}%"
    echo "  建议: 使用 free -h 和 docker stats 排查占用，必要时增加 swap 或限制容器内存。"
    found=1
  fi
  if printf '%s\n' "$disk_pct" | grep -Eq '^[0-9]+$' && [ "$disk_pct" -ge "$disk_crit" ]; then
    echo "- 根分区占用严重: ${disk_pct}% >= ${disk_crit}%"
    echo "  建议: 立即清理日志、缓存、旧备份或 Docker 无用数据。"
    found=1
  elif printf '%s\n' "$disk_pct" | grep -Eq '^[0-9]+$' && [ "$disk_pct" -ge "$disk_warn" ]; then
    echo "- 根分区占用偏高: ${disk_pct}% >= ${disk_warn}%"
    echo "  建议: 使用 ncdu/du 定位大目录，并关注日志和备份增长。"
    found=1
  fi
  load_int="${load_avg%%.*}"
  if printf '%s\n' "$load_int" | grep -Eq '^[0-9]+$' &&
    printf '%s\n' "$cores" | grep -Eq '^[0-9]+$' &&
    [ "$cores" -gt 0 ] && [ "$load_int" -ge "$cores" ]; then
    echo "- 系统负载偏高: ${load_avg} / ${cores}核"
    echo "  建议: 使用 uptime/top 查看负载来源，重点检查 CPU、磁盘 IO 和网络任务。"
    found=1
  fi

  if has_cmd docker; then
    if docker info >/dev/null 2>&1; then
      local _bad _bname _bstatus
      _bad=""
      while IFS=$'\t' read -r _bname _bstatus; do
        [ -z "$_bname" ] && continue
        list_has_word "$_bname" "$UA_IGNORE_CONTAINERS" && continue
        case "$_bstatus" in
          Up*) ;;
          *) _bad="${_bad}  $_bname  $_bstatus\n" ;;
        esac
      done < <(docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null)
      if [ -n "$_bad" ]; then
        echo "- Docker 异常容器:"
        printf '%b' "$_bad"
        echo "  建议: 不再使用可执行 ua ignore container <名称>；仍需使用先查看日志再重启。"
        found=1
      fi

      # 检测 Docker Compose 项目部分容器停止的异常
      local ps_out bad_projects
      ps_out="$(docker ps -a --format '{{.Names}}\t{{.Label "com.docker.compose.project"}}\t{{.State.Running}}' 2>/dev/null)"
      if [ -n "$ps_out" ]; then
        bad_projects="$(printf '%s\n' "$ps_out" | awk -F'\t' '
          $2 != "" {
            proj=$2
            total[proj]++
            if ($3 == "true") running[proj]++
          }
          END {
            for (p in total) {
              run_count = running[p] ? running[p] : 0
              if (run_count < total[p]) {
                printf "%s (%d/%d运行中) ", p, run_count, total[p]
              }
            }
          }
        ')"
        if [ -n "$bad_projects" ]; then
          echo "- Compose 项目有容器已停止: $bad_projects"
          echo "  建议: 运行 ua docker 并选择 8 进入项目管理，对该项目进行一键 Compose Up 重启拉起。"
          found=1
        fi
      fi
    else
      echo "- Docker 服务未运行或不可访问"
      echo "  建议: 使用 systemctl status docker 查看原因，必要时执行 systemctl restart docker。"
      found=1
    fi
  fi

  if has_cmd systemctl; then
    local _monitor_svcs
    _monitor_svcs="${UA_MONITOR_SERVICES:-caddy}"
    # shellcheck disable=SC2086
    for svc in $_monitor_svcs; do
      list_has_word "$svc" "$UA_IGNORE_SERVICES" && continue
      if systemctl list-unit-files "${svc}.service" --no-legend 2>/dev/null | grep -q . &&
        ! systemctl is-active --quiet "$svc" 2>/dev/null; then
        echo "- 服务未运行: $svc"
        echo "  建议: 需要该服务时执行 systemctl start $svc；不再使用可执行 ua ignore service $svc。"
        found=1
      fi
    done
  fi

  if has_cmd rclone; then
    if [ "${UA_STATUS_SKIP_RCLONE:-0}" = "1" ]; then
      echo "- rclone remote 检测已跳过（UA_STATUS_SKIP_RCLONE=1）"
    else
      local _rclone_count
      _rclone_count="$(rclone listremotes 2>/dev/null | wc -l)"
      if [ "$_rclone_count" -gt 0 ]; then
        echo -e "${gl_huang}检测 ${_rclone_count} 个 rclone remote，每个最多等待 ${check_timeout}s，请稍候...${gl_bai}"
      fi
      failed_remotes=""
      while IFS= read -r remote; do
        [ -z "$remote" ] && continue
        list_has_word "$remote" "$UA_IGNORE_RCLONE_REMOTES" && continue
        if has_cmd timeout; then
          output="$(timeout "$check_timeout" rclone lsd "${remote}:" 2>&1 >/dev/null)"
          rc=$?
          [ "$rc" -eq 124 ] && status="timeout" || status="fail"
        else
          output="$(rclone lsd "${remote}:" 2>&1 >/dev/null)"
          rc=$?
          status="fail"
        fi
        if [ "$rc" -ne 0 ]; then
          failed_remotes="${failed_remotes}${remote}(${status}) "
        fi
      done < <(rclone listremotes 2>/dev/null | sed 's/:$//')
      if [ -n "$failed_remotes" ]; then
        echo "- rclone remote 连接异常: $failed_remotes"
        echo "  连接测试超时: ${check_timeout}s/remote"
        echo "  建议: 执行 ua rclone 检测配置；确认不用的 remote 可执行 ua ignore rclone <名称>。"
        found=1
      fi
    fi
  fi

  [ "$found" -eq 0 ] && echo "- 暂无明显异常。"
}

