docker_uninstall() {
  need_root || return 1
  if confirm_danger "卸载 Docker，并清理容器、镜像、网络和卷" "docker rm/rmi/prune + remove docker packages"; then
    log_action "uninstall Docker"
    # 仅在 daemon 可访问时清理运行时资源
    if docker info >/dev/null 2>&1; then
      docker ps -a -q 2>/dev/null | xargs -r docker rm -f
      docker images -q 2>/dev/null | xargs -r docker rmi -f
      docker network prune -f 2>/dev/null || true
      docker volume prune -f 2>/dev/null || true
    fi
    remove_pkg docker docker.io docker-compose docker-ce docker-ce-cli containerd.io
  fi
}

docker_container_list() {
  printf "%-12s %-25s %-22s %-25s %-30s\n" "CONTAINER ID" "NAMES" "TYPE" "STATUS" "PORTS"
  docker ps -a --format '{{.ID}}\t{{.Names}}\t{{if .Label "com.docker.compose.project"}}Compose ({{.Label "com.docker.compose.project"}}){{else}}docker run{{end}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null | \
    awk -F'\t' '{printf "%-12s %-25s %-22s %-25s %-30s\n", $1, $2, $3, $4, $5}'
}

docker_container_network_overview() {
  echo "容器网络"
  echo "------------------------------------------------------------"
  printf "%-25s %-25s %-20s\n" "容器名称" "网络名称" "IP地址"

  local _ids
  _ids="$(docker ps -a -q 2>/dev/null)"
  [ -z "$_ids" ] && return 0
  # 一次性批量 inspect，减少 N 次子进程开销
  # shellcheck disable=SC2086
  docker inspect --format '{{.Name}}{{range $network, $config := .NetworkSettings.Networks}} {{$network}} {{$config.IPAddress}}{{end}}' \
    $_ids 2>/dev/null | \
    awk '{
      name=substr($1,2);
      if (NF < 3) {
        printf "%-25s %-25s %-20s\n", name, "-", "-";
      } else {
        for (i=2; i<=NF; i+=2) printf "%-25s %-25s %-20s\n", name, $i, $(i+1);
      }
    }'
}

