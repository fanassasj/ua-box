system_check_admin_key_login() {
  local user="${1:-admin}"
  local home_dir
  local key_file
  local item

  if ! getent passwd "$user" >/dev/null 2>&1; then
    echo "用户不存在: $user"
    return 1
  fi

  home_dir="$(getent passwd "$user" | cut -d: -f6)"
  key_file="$home_dir/.ssh/authorized_keys"
  echo "检查用户: $user"
  echo "Home: $home_dir"
  echo -e "${gl_kjlan}------------------------${gl_bai}"

  for item in "$home_dir" "$home_dir/.ssh" "$key_file"; do
    if [ -e "$item" ]; then
      stat -c '%n  %U:%G  %a' "$item"
    else
      echo "缺失: $item"
    fi
  done

  echo -e "${gl_kjlan}------------------------${gl_bai}"
  if has_cmd sshd; then
    sshd -T -C user="$user",host=localhost,addr=127.0.0.1 2>/dev/null | grep -E '^(permitrootlogin|passwordauthentication|pubkeyauthentication|strictmodes|authorizedkeysfile)' || true
  fi

  echo ""
  echo "建议权限:"
  echo "  chown $user:$user $home_dir $home_dir/.ssh $key_file"
  echo "  chmod 755 $home_dir"
  echo "  chmod 700 $home_dir/.ssh"
  echo "  chmod 600 $key_file"
}

