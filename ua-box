system_bbr_menu() {
  local cur_cc cur_qdisc choice
  while true; do
    cur_cc="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo '未知')"
    cur_qdisc="$(sysctl -n net.core.default_qdisc 2>/dev/null || echo '未知')"
    clear
    echo -e "${gl_kjlan}BBR 拥塞控制与网络调优${gl_bai}"
    echo -e "${gl_kjlan}------------------------${gl_bai}"
    echo -e "当前拥塞控制: ${gl_lv}${cur_cc}${gl_bai}"
    echo -e "当前队列算法: ${gl_lv}${cur_qdisc}${gl_bai}"
    echo -e "${gl_kjlan}------------------------${gl_bai}"
    echo -e "${gl_kjlan}1.   ${gl_bai}开启 BBR"
    echo -e "${gl_kjlan}2.   ${gl_bai}关闭 BBR（恢复 cubic）"
    echo -e "${gl_kjlan}3.   ${gl_bai}开启网络内核协议栈高级优化"
    echo -e "${gl_kjlan}4.   ${gl_bai}恢复默认 TCP 参数"
    echo -e "${gl_kjlan}0.   ${gl_bai}返回"
    read -r -e -p "请输入你的选择: " choice || break

    case "$choice" in
      1)
        need_root || { pause; continue; }
        local virt_type
        virt_type="$(get_virt)"
        if [ "$virt_type" = "OPENVZ" ] || [ "$virt_type" = "LXC" ]; then
          echo -e "${gl_hong}架构为 ${virt_type}，不支持在容器内开启 BBR（需在宿主机开启）。${gl_bai}"
          pause; continue
        fi
        local kver major minor
        kver="$(uname -r)"
        major="$(printf '%s' "$kver" | cut -d. -f1)"
        minor="$(printf '%s' "$kver" | cut -d. -f2)"
        if [ "$major" -lt 4 ] || { [ "$major" -eq 4 ] && [ "$minor" -lt 9 ]; }; then
          echo -e "${gl_hong}当前内核 $kver 不支持 BBR（需要 >= 4.9）${gl_bai}"
          pause; continue
        fi
        if ! sysctl net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q "bbr"; then
          modprobe tcp_bbr 2>/dev/null || true
        fi
        if ! sysctl net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q "bbr"; then
          echo -e "${gl_hong}内核目前不支持或无法加载 BBR 模块。${gl_bai}"
          pause; continue
        fi
        local sysctl_conf="/etc/sysctl.d/99-ua-bbr.conf"
        cat > "$sysctl_conf" <<'SYSCTL'
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
SYSCTL
        sysctl -p "$sysctl_conf" > /dev/null 2>&1 || sysctl --system > /dev/null 2>&1 || true
        local now_cc
        now_cc="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
        if [ "$now_cc" = "bbr" ]; then
          log_action "BBR enabled"
          echo -e "${gl_lv}BBR 已成功开启！${gl_bai}"
        else
          echo -e "${gl_hong}BBR 开启失败，当前: $now_cc${gl_bai}"
        fi
        pause
        ;;
      2)
        need_root || { pause; continue; }
        rm -f /etc/sysctl.d/99-ua-bbr.conf
        sysctl -w net.ipv4.tcp_congestion_control=cubic > /dev/null 2>&1 || true
        sysctl -w net.core.default_qdisc=pfifo_fast > /dev/null 2>&1 || true
        log_action "BBR disabled, restored cubic"
        echo -e "${gl_lv}已恢复 cubic 拥塞控制。${gl_bai}"
        pause
        ;;
      3)
        need_root || { pause; continue; }
        local sysctl_tcp_conf="/etc/sysctl.d/99-ua-tcp-tune.conf"
        cat > "$sysctl_tcp_conf" <<'TCPTUNE'
# UA Box TCP High Performance Tuning
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
net.ipv4.tcp_keepalive_time = 600
net.ipv4.tcp_max_syn_backlog = 16384
net.ipv4.tcp_max_tw_buckets = 5000
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_rmem = 4096 87380 67108864
net.ipv4.tcp_wmem = 4096 65536 67108864
net.core.somaxconn = 4096
net.core.netdev_max_backlog = 25000
TCPTUNE
        sysctl -p "$sysctl_tcp_conf" > /dev/null 2>&1 || sysctl --system > /dev/null 2>&1 || true
        log_action "TCP kernel parameters optimized"
        echo -e "${gl_lv}TCP 协议栈网络高级优化参数已成功加载！${gl_bai}"
        pause
        ;;
      4)
        need_root || { pause; continue; }
        rm -f /etc/sysctl.d/99-ua-tcp-tune.conf
        sysctl --system >/dev/null 2>&1 || true
        log_action "TCP kernel optimization removed"
        echo -e "${gl_lv}已清除 TCP 协议栈网络高级优化配置，恢复默认系统参数。${gl_bai}"
        pause
        ;;
      0) return 0 ;;
      *) echo "无效输入"; pause ;;
    esac
  done
}

system_firewall_menu() {
  need_root || return 1
  local fw
  if has_cmd ufw; then
    fw=ufw
  elif has_cmd firewall-cmd; then
    fw=firewalld
  elif has_cmd iptables; then
    fw=iptables
  else
    fw=none
  fi

  case "$fw" in
    ufw)
      while true; do
        clear
        echo -e "${gl_kjlan}防火墙管理${gl_bai}"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "检测到防火墙工具: ${gl_lv}ufw${gl_bai}"
        echo -e "当前状态: $(ufw status | head -n1)"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "${gl_kjlan}1.  ${gl_bai}查看规则"
        echo -e "${gl_kjlan}2.  ${gl_bai}放行端口（TCP）"
        echo -e "${gl_kjlan}3.  ${gl_bai}放行端口（UDP）"
        echo -e "${gl_kjlan}4.  ${gl_bai}删除规则"
        echo -e "${gl_kjlan}5.  ${gl_bai}启用防火墙"
        echo -e "${gl_kjlan}6.  ${gl_bai}禁用防火墙"
        echo -e "${gl_kjlan}0.  ${gl_bai}返回"
        read -r -e -p "请输入你的选择: " choice || break
        case "$choice" in
          1) ufw status numbered; pause ;;
          2)
            read -r -e -p "请输入要放行的 TCP 端口（如 8080 或 8080:8090）: " port
            [ -n "$port" ] && ufw allow "${port}/tcp" && log_action "ufw allow ${port}/tcp"
            pause
            ;;
          3)
            read -r -e -p "请输入要放行的 UDP 端口（如 51820）: " port
            [ -n "$port" ] && ufw allow "${port}/udp" && log_action "ufw allow ${port}/udp"
            pause
            ;;
          4)
            ufw status numbered
            read -r -e -p "请输入要删除的规则编号: " num
            [ -n "$num" ] && ufw delete "$num"
            pause
            ;;
          5) need_root && ufw --force enable && log_action "ufw enabled"; pause ;;
          6) need_root && ufw disable && log_action "ufw disabled"; pause ;;
          0) return 0 ;;
          *) echo "无效输入"; pause ;;
        esac
      done
      ;;
    firewalld)
      while true; do
        clear
        echo -e "${gl_kjlan}防火墙管理${gl_bai}"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "检测到防火墙工具: ${gl_lv}firewalld${gl_bai}"
        echo -e "当前状态: $(firewall-cmd --state 2>/dev/null)"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "${gl_kjlan}1.  ${gl_bai}查看开放端口"
        echo -e "${gl_kjlan}2.  ${gl_bai}放行端口（TCP）"
        echo -e "${gl_kjlan}3.  ${gl_bai}放行端口（UDP）"
        echo -e "${gl_kjlan}4.  ${gl_bai}移除端口规则"
        echo -e "${gl_kjlan}0.  ${gl_bai}返回"
        read -r -e -p "请输入你的选择: " choice || break
        case "$choice" in
          1) firewall-cmd --list-ports; pause ;;
          2)
            read -r -e -p "请输入要放行的 TCP 端口: " port
            if [ -n "$port" ]; then
              port="${port//:/-}"
              firewall-cmd --permanent --add-port="${port}/tcp" && firewall-cmd --reload && log_action "firewalld add ${port}/tcp"
            fi
            pause
            ;;
          3)
            read -r -e -p "请输入要放行的 UDP 端口: " port
            if [ -n "$port" ]; then
              port="${port//:/-}"
              firewall-cmd --permanent --add-port="${port}/udp" && firewall-cmd --reload && log_action "firewalld add ${port}/udp"
            fi
            pause
            ;;
          4)
            read -r -e -p "请输入要移除的端口（格式如 8080/tcp）: " portproto
            if [ -n "$portproto" ]; then
              portproto="${portproto//:/-}"
              firewall-cmd --permanent --remove-port="$portproto" && firewall-cmd --reload
            fi
            pause
            ;;
          0) return 0 ;;
          *) echo "无效输入"; pause ;;
        esac
      done
      ;;
    iptables)
      while true; do
        clear
        echo -e "${gl_kjlan}防火墙管理${gl_bai}"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "检测到防火墙工具: ${gl_lv}iptables${gl_bai}"
        echo -e "${gl_kjlan}------------------------${gl_bai}"
        echo -e "${gl_kjlan}1.  ${gl_bai}查看当前规则（INPUT 链）"
        echo -e "${gl_kjlan}2.  ${gl_bai}放行端口（TCP）"
        echo -e "${gl_kjlan}3.  ${gl_bai}放行端口（UDP）"
        echo -e "${gl_kjlan}4.  ${gl_bai}删除规则"
        echo -e "${gl_kjlan}5.  ${gl_bai}保存规则（尝试持久化）"
        echo -e "${gl_kjlan}0.  ${gl_bai}返回"
        read -r -e -p "请输入你的选择: " choice || break
        case "$choice" in
          1) iptables -L INPUT -n --line-numbers; pause ;;
          2)
            read -r -e -p "请输入要放行的 TCP 端口: " port
            [ -n "$port" ] && iptables -I INPUT -p tcp --dport "$port" -j ACCEPT && log_action "iptables allow ${port}/tcp"
            echo -e "${gl_huang}警告: iptables 规则将在重启后失效，请选择 5 进行保存。${gl_bai}"
            pause
            ;;
          3)
            read -r -e -p "请输入要放行的 UDP 端口: " port
            [ -n "$port" ] && iptables -I INPUT -p udp --dport "$port" -j ACCEPT && log_action "iptables allow ${port}/udp"
            echo -e "${gl_huang}警告: iptables 规则将在重启后失效，请选择 5 进行保存。${gl_bai}"
            pause
            ;;
          4)
            iptables -L INPUT -n --line-numbers
            read -r -e -p "请输入要删除的 INPUT 规则编号: " num
            [ -n "$num" ] && iptables -D INPUT "$num"
            pause
            ;;
          5)
            if has_cmd netfilter-persistent; then
              netfilter-persistent save && echo "已保存 (netfilter-persistent)。"
            elif [ -f /etc/sysconfig/iptables ]; then
              iptables-save > /etc/sysconfig/iptables && echo "已保存 (/etc/sysconfig/iptables)。"
            elif [ -d /etc/iptables ]; then
              iptables-save > /etc/iptables/rules.v4 && echo "已保存 (/etc/iptables/rules.v4)。"
            else
              echo -e "${gl_hong}未找到标准的 iptables 持久化路径，请手动保存。${gl_bai}"
            fi
            pause
            ;;
          0) return 0 ;;
          *) echo "无效输入"; pause ;;
        esac
      done
      ;;
    none)
      clear
      echo -e "${gl_kjlan}防火墙管理${gl_bai}"
      echo -e "${gl_kjlan}------------------------${gl_bai}"
      echo -e "${gl_huang}未检测到 ufw / firewalld / iptables，无法管理防火墙。${gl_bai}"
      echo "可先安装 ufw：ua install ufw"
      ;;
  esac
}
