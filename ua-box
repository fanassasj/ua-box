        read -r -e -p "请输入要恢复的备份文件名: " bak
        if [ -z "$bak" ]; then
          echo "已取消。"
        else
          local _bak_path="$UA_BOX_BACKUP_DIR/$bak"
          if [ ! -f "$_bak_path" ]; then
            echo -e "${gl_hong}未找到备份文件: $_bak_path${gl_bai}"
          elif confirm_danger "从备份覆盖当前脚本" "$_bak_path"; then
            local _src
            _src="$(readlink -f "$0" 2>/dev/null || echo "$0")"
            backup_self && cp "$_bak_path" "$_src" && chmod +x "$_src"
