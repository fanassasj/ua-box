  # 检查 JSON 语法，避免重启后 Docker 无法启动
  if [ -f /etc/docker/daemon.json ]; then
    if has_cmd python3; then
      if ! python3 -m json.tool /etc/docker/daemon.json >/dev/null 2>&1; then
