docker_container_port_access() {
  local mode="$1"
  local proto port source_ip

  need_root || return 1
  if ! has_cmd iptables; then
    echo "未找到 iptables，无法管理 Docker 容器端口访问规则。"
    return 1
  fi

  echo "该功能通过 DOCKER-USER 链放行/阻断容器端口流量，不会为未发布的端口创建 Docker 映射。"
  read -r -e -p "请输入容器端口: " port
  read -r -e -p "请输入协议，回车默认 tcp: " proto
  read -r -e -p "限制来源 IP/CIDR，回车表示所有来源: " source_ip
  proto="${proto:-tcp}"

  if [ -z "$port" ]; then
    echo "未输入端口。"
    return 1
  fi

  iptables -N DOCKER-USER 2>/dev/null || true

  if [ "$mode" = "close" ]; then
    if [ -n "$source_ip" ]; then
      iptables -C DOCKER-USER -s "$source_ip" -p "$proto" --dport "$port" -j DROP 2>/dev/null ||
        iptables -I DOCKER-USER 1 -s "$source_ip" -p "$proto" --dport "$port" -j DROP
    else
      iptables -C DOCKER-USER -p "$proto" --dport "$port" -j DROP 2>/dev/null ||
        iptables -I DOCKER-USER 1 -p "$proto" --dport "$port" -j DROP
    fi
    log_action "close Docker container port $proto/$port ${source_ip:-all}"
    echo "已关闭容器端口访问: $proto/$port ${source_ip:-所有来源}"
  else
    if [ -n "$source_ip" ]; then
      while iptables -C DOCKER-USER -s "$source_ip" -p "$proto" --dport "$port" -j DROP 2>/dev/null; do
        iptables -D DOCKER-USER -s "$source_ip" -p "$proto" --dport "$port" -j DROP
      done
    else
      while iptables -C DOCKER-USER -p "$proto" --dport "$port" -j DROP 2>/dev/null; do
        iptables -D DOCKER-USER -p "$proto" --dport "$port" -j DROP
      done
    fi
    log_action "open Docker container port $proto/$port ${source_ip:-all}"
    echo "已放行容器端口访问: $proto/$port ${source_ip:-所有来源}"
  fi
}

