resolve_dns() {
  local domain="$1"
  local type="${2:-A}"
  if has_cmd curl; then
    curl -sH "accept: application/dns-json" "https://cloudflare-dns.com/dns-query?name=${domain}&type=${type}" 2>/dev/null | \
      grep -oE '"data":"[^"]+"' | cut -d'"' -f4
  elif has_cmd wget; then
    wget -qO- --header="accept: application/dns-json" "https://cloudflare-dns.com/dns-query?name=${domain}&type=${type}" 2>/dev/null | \
      grep -oE '"data":"[^"]+"' | cut -d'"' -f4
  fi
}

caddy_docker_install() {
  need_root || return 1
  docker_require || install_docker || return 1

  if docker_container_exists caddy; then
    docker start caddy
    echo "Caddy 容器已存在并已启动。"
    return 0
  fi

  local port_80 port_443
  read -r -e -p "请输入 Caddy HTTP(80) 映射端口，回车默认 80: " u_80
  port_80="${u_80:-80}"
  read -r -e -p "请输入 Caddy HTTPS(443) 映射端口，回车默认 443: " u_443
  port_443="${u_443:-443}"

  for p in "$port_80" "$port_443"; do
    if ! printf '%s\n' "$p" | grep -Eq '^[0-9]+$'; then
      echo "错误: 端口必须是纯数字。"
      return 1
    fi
    if is_port_taken "$p"; then
      echo -e "${gl_hong}错误:${gl_bai} 端口 $p 已被系统占用，请先释放该端口，或者指定其他映射端口。"
      return 1
    fi
  done

  mkdir -p /root/caddy /root/caddy_data /root/caddy_config
  if [ ! -f /root/caddy/Caddyfile ]; then
    cat > /root/caddy/Caddyfile <<EOF
# Caddy 配置文件
# 您可以在这里添加您的反代或静态站配置
EOF
  fi

  log_action "install Caddy Docker (80:$port_80, 443:$port_443)"
  docker run -d \
    --name caddy \
    --restart unless-stopped \
    -p "$port_80":80 -p "$port_443":443 \
    -v /root/caddy/Caddyfile:/etc/caddy/Caddyfile \
    -v /root/caddy_data:/data \
    -v /root/caddy_config:/config \
    caddy:latest

  echo "Caddy Docker 容器部署完成。"
  echo "配置文件已映射到宿主机: /root/caddy/Caddyfile"
}

caddy_add_reverse_proxy() {
  need_root || return 1

  local domain upstream cfg_file
  if docker_container_exists caddy; then
    cfg_file="/root/caddy/Caddyfile"
  else
    cfg_file="/etc/caddy/Caddyfile"
  fi

  read -r -e -p "请输入域名，如 example.com: " domain
  read -r -e -p "请输入反代目标，如 http://127.0.0.1:3000: " upstream
  if [ -z "$domain" ] || [ -z "$upstream" ]; then
    echo "域名和反代目标不能为空。"
    return 1
  fi

  # DNS 解析与本机公网 IP 一致性校验
  local resolved_ip resolved_ip6 local_ip_v4 local_ip_v6
  echo "正在获取公网 IP 并验证域名解析指向，请稍候..."
  local_ip_v4="$(public_ip)"
  local_ip_v6="$(public_ipv6)"
  resolved_ip="$(resolve_dns "$domain" "A" | head -n 1)"
  resolved_ip6="$(resolve_dns "$domain" "AAAA" | head -n 1)"

  local dns_ok=0
  if [ -n "$resolved_ip" ] && [ "$resolved_ip" = "$local_ip_v4" ]; then
    dns_ok=1
  fi
  if [ -n "$resolved_ip6" ] && [ "$resolved_ip6" = "$local_ip_v6" ]; then
    dns_ok=1
  fi

  if [ "$dns_ok" -eq 0 ]; then
    echo -e "${gl_huang}⚠️  警告:${gl_bai} 域名 $domain 解析到的公网 IP 与本机不匹配。"
    echo -e "  域名解析到: IPv4: ${gl_lv}${resolved_ip:-无}${gl_bai} / IPv6: ${gl_lv}${resolved_ip6:-无}${gl_bai}"
    echo -e "  本机公网IP: IPv4: ${gl_lv}${local_ip_v4:-无}${gl_bai} / IPv6: ${gl_lv}${local_ip_v6:-无}${gl_bai}"
    echo "  如果强行添加，Caddy 在为该域名申请 SSL 证书时极大概率会报错或阻塞。"
    read -r -e -p "是否仍然强制添加反代配置？输入 y 继续，回车取消: " _caddy_confirm
    [ "$_caddy_confirm" != "y" ] && [ "$_caddy_confirm" != "Y" ] && echo "已取消操作。" && return 1
  else
    echo -e "${gl_lv}✓ DNS 解析校验通过，域名已正确指向本机。${gl_bai}"
  fi

  mkdir -p "$(dirname "$cfg_file")"
  touch "$cfg_file"
  cp "$cfg_file" "${cfg_file}.ua-box.$(date +%Y%m%d-%H%M%S).bak"
  cat >> "$cfg_file" <<EOF

$domain {
    reverse_proxy $upstream
}
EOF
  log_action "add caddy reverse proxy $domain -> $upstream"
  
  if docker_container_exists caddy; then
    if docker_container_running caddy; then
      docker exec -w /etc/caddy caddy caddy fmt --overwrite Caddyfile 2>/dev/null || true
      docker exec -w /etc/caddy caddy caddy reload
    fi
  elif has_cmd caddy; then
    caddy fmt --overwrite /etc/caddy/Caddyfile 2>/dev/null || true
    caddy validate --config /etc/caddy/Caddyfile || return 1
    svc reload caddy 2>/dev/null || svc restart caddy 2>/dev/null || true
  fi
  echo "已追加 Caddy 反代配置并重载服务。"
}

