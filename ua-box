npm_install() {
  need_root || return 1
  docker_require || install_docker || return 1

  local name
  name="$(npm_container_name)"
  if docker_container_exists "$name"; then
    docker start "$name"
    echo "Nginx Proxy Manager 容器已存在并已启动: $name"
    return 0
  fi

  local port_80 port_443 port_81
  echo "提示: 如果你的服务器上已经运行了其他 Web 服务(如 Caddy 或 Nginx)，绑定默认的 80/443 会导致冲突。"
  read -r -e -p "请输入 HTTP(80) 映射端口，回车默认 80: " u_80
  port_80="${u_80:-80}"
  read -r -e -p "请输入 HTTPS(443) 映射端口，回车默认 443: " u_443
  port_443="${u_443:-443}"
  read -r -e -p "请输入管理后台(81) 映射端口，回车默认 81: " u_81
  port_81="${u_81:-81}"

  for p in "$port_80" "$port_443" "$port_81"; do
    if ! printf '%s\n' "$p" | grep -Eq '^[0-9]+$'; then
      echo "错误: 端口必须是纯数字。"
      return 1
    fi
    if is_port_taken "$p"; then
      echo -e "${gl_hong}错误:${gl_bai} 端口 $p 已被系统占用，请先释放该端口，或者在安装时指定其他映射端口。"
      return 1
    fi
  done

  mkdir -p /root/nginx-proxy-manager/data /root/nginx-proxy-manager/letsencrypt
  log_action "install Nginx Proxy Manager (80:$port_80, 443:$port_443, 81:$port_81)"
  docker run -d \
    --name "$name" \
    --restart unless-stopped \
    -p "$port_80":80 -p "$port_81":81 -p "$port_443":443 \
    -v /root/nginx-proxy-manager/data:/data \
    -v /root/nginx-proxy-manager/letsencrypt:/etc/letsencrypt \
    jc21/nginx-proxy-manager:latest
  echo "Nginx Proxy Manager 已部署。如果映射了非标准端口，请访问对应的映射端口，例如管理后台: http://$(get_display_ip):$port_81"
