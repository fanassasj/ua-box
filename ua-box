system_set_swap() {
  need_root || return 1

  local current new_swap
  current="$(free -m | awk '/^Swap:/ {printf "%dMB/%dMB", $3, $2}')"
  echo "当前虚拟内存: ${current:-未知}"
  echo "1. 分配 1024MB"
  echo "2. 分配 2048MB"
  echo "3. 自定义大小"
  echo "4. 关闭并删除 /swapfile"
  echo "0. 取消"
  read -r -e -p "请输入你的选择: " choice

  case "$choice" in
    1) new_swap=1024 ;;
    2) new_swap=2048 ;;
    3) read -r -e -p "请输入虚拟内存大小 MB: " new_swap ;;
    4)
      if confirm_danger "关闭并删除 /swapfile" "/swapfile"; then
        swapoff /swapfile 2>/dev/null || true
        sed -i '\|/swapfile swap swap|d' /etc/fstab
        rm -f /swapfile
        echo "已删除 /swapfile。"
      fi
      return 0
      ;;
    0) return 0 ;;
    *) echo "无效输入"; return 1 ;;
  esac

  if ! printf '%s\n' "$new_swap" | grep -Eq '^[0-9]+$' || [ "$new_swap" -lt 128 ]; then
    echo "虚拟内存大小必须是大于等于 128 的 MB 数值。"
    return 1
  fi

  if confirm_danger "重建 /swapfile 并设置虚拟内存为 ${new_swap}MB" "/swapfile"; then
    log_action "set swap ${new_swap}MB"
    swapoff /swapfile 2>/dev/null || true
    sed -i '\|/swapfile swap swap|d' /etc/fstab
    rm -f /swapfile
    if has_cmd fallocate; then
      fallocate -l "${new_swap}M" /swapfile || dd if=/dev/zero of=/swapfile bs=1M count="$new_swap"
    else
      dd if=/dev/zero of=/swapfile bs=1M count="$new_swap"
    fi
    chmod 600 /swapfile
    mkswap /swapfile
    swapon /swapfile
    echo "/swapfile swap swap defaults 0 0" >> /etc/fstab
    echo "虚拟内存已设置为 ${new_swap}MB。"
  fi
}

