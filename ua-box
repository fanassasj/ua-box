tmux_open_session() {
  local name="$1"
  [ -z "$name" ] && name="ua"
  tmux_require || return 1

  # 若会话不存在则静默创建
  if ! tmux has-session -t "$name" 2>/dev/null; then
    tmux new-session -d -s "$name"
  fi

  # 注入状态栏常驻退出向导 (高亮红底白字)
  tmux set-option -t "$name" status-right-length 50 2>/dev/null || true
  tmux set-option -t "$name" status-right " 退出: Ctrl+B, D " 2>/dev/null || true
  tmux set-option -t "$name" status-right-style "bg=red,fg=white,bold" 2>/dev/null || true

  # 附加挂载
  tmux attach-session -t "$name"
}

