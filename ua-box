#!/usr/bin/env bash

UA_BOX_VERSION="0.6.0"
UA_BOX_NAME="UA Box"
SCRIPT_REAL_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
UA_BOX_HOME="$(cd "$(dirname "$SCRIPT_REAL_PATH")" && pwd)"
UA_BOX_CONFIG="${UA_BOX_CONFIG:-$UA_BOX_HOME/config}"
UA_BOX_LOG_DIR="${UA_BOX_LOG_DIR:-$UA_BOX_HOME/logs}"
UA_BOX_LOG_FILE="${UA_BOX_LOG_FILE:-$UA_BOX_LOG_DIR/ua-box.log}"
UA_BOX_BACKUP_DIR="${UA_BOX_BACKUP_DIR:-$UA_BOX_HOME/backups}"
UA_BOX_TMP_DIR="${UA_BOX_TMP_DIR:-$(mktemp -d /tmp/ua-box.XXXXXX)}"
trap 'rm -rf "$UA_BOX_TMP_DIR"' EXIT
gl_hui='\033[37m'
gl_hong='\033[31m'
gl_lv='\033[32m'
gl_huang='\033[33m'
gl_lan='\033[34m'
gl_bai='\033[0m'
gl_zi='\033[35m'
gl_kjlan='\033[96m'

WARP_MANAGER_SCRIPT="https://gitlab.com/fscarmen/warp/-/raw/main/menu.sh"

DOCKER_INSTALL_SCRIPT="https://get.docker.com"
DOCKER_INSTALL_SCRIPTS="https://get.docker.com https://raw.githubusercontent.com/docker/docker-install/master/install.sh https://github.com/docker/docker-install/raw/master/install.sh https://linuxmirrors.cn/docker.sh"
RCLONE_INSTALL_SCRIPT="https://rclone.org/install.sh"
YABS_SCRIPT="https://raw.githubusercontent.com/masonr/yet-another-bench-script/master/yabs.sh"
BENCH_SCRIPT="https://bench.sh"
OPENAI_CHECK_SCRIPT="https://cdn.jsdelivr.net/gh/missuo/OpenAI-Checker/openai.sh"
REGION_UNLOCK_SCRIPT="https://raw.githubusercontent.com/lmc999/RegionRestrictionCheck/main/check.sh"
YEAHWU_UNLOCK_SCRIPT="https://github.com/yeahwu/check/raw/main/check.sh"
MTR_TRACE_SCRIPT="https://raw.githubusercontent.com/zhucaidan/mtr_trace/main/mtr_trace.sh"
IABC_SPEEDTEST_SCRIPT="https://raw.githubusercontent.com/i-abc/Speedtest/main/speedtest.sh"
FUSION_TEST_SCRIPT="https://gitlab.com/spiritysdx/za/-/raw/main/ecs.sh"
GB5_SCRIPT="https://raw.githubusercontent.com/i-abc/GB5/main/gb5-test.sh"
REINSTALL_SCRIPT="https://raw.githubusercontent.com/bin456789/reinstall/main/reinstall.sh"
BESTTRACE_SCRIPT="https://raw.githubusercontent.com/zhanghanyun/backtrace/main/install.sh"
SUPERSPEED_SCRIPT="https://raw.githubusercontent.com/uxh/superspeed/master/superspeed.sh"
LIMIT_SHUTDOWN_SCRIPT="/root/ua-box/limit-shutdown.sh"
DEFAULT_WORKSPACE_PREFIX="work"
DEFAULT_RCLONE_MOUNT_ARGS="--vfs-cache-mode writes"
UA_BOX_UPDATE_URL="https://raw.githubusercontent.com/fanassasj/ua-box/main/ua-box"
UA_IGNORE_CONTAINERS=""
UA_IGNORE_SERVICES=""
UA_IGNORE_RCLONE_REMOTES=""
UA_STATUS_DISK_WARN=80
UA_STATUS_DISK_CRIT=90
UA_APT_UPDATE_INTERVAL=60
UA_MONITOR_SERVICES="caddy"
UA_STATUS_SKIP_RCLONE=0

init_ua_box() {
  mkdir -p "$UA_BOX_HOME" "$UA_BOX_LOG_DIR" "$UA_BOX_BACKUP_DIR"
  if [ ! -f "$UA_BOX_CONFIG" ]; then
    cat > "$UA_BOX_CONFIG" <<EOF
# UA Box 配置文件
# 修改后重新运行 ua 生效。

DEFAULT_WORKSPACE_PREFIX="work"
DEFAULT_RCLONE_MOUNT_ARGS="--vfs-cache-mode writes"
UA_BOX_UPDATE_URL="https://raw.githubusercontent.com/fanassasj/ua-box/main/ua-box"
UA_IGNORE_CONTAINERS=""
UA_IGNORE_SERVICES=""
UA_IGNORE_RCLONE_REMOTES=""
UA_STATUS_DISK_WARN=80
UA_STATUS_DISK_CRIT=90
UA_APT_UPDATE_INTERVAL=60
UA_MONITOR_SERVICES="caddy"
UA_STATUS_SKIP_RCLONE=0

WARP_MANAGER_SCRIPT="$WARP_MANAGER_SCRIPT"

DOCKER_INSTALL_SCRIPT="$DOCKER_INSTALL_SCRIPT"
DOCKER_INSTALL_SCRIPTS="$DOCKER_INSTALL_SCRIPTS"
RCLONE_INSTALL_SCRIPT="$RCLONE_INSTALL_SCRIPT"
YABS_SCRIPT="$YABS_SCRIPT"
BENCH_SCRIPT="$BENCH_SCRIPT"
OPENAI_CHECK_SCRIPT="$OPENAI_CHECK_SCRIPT"
REGION_UNLOCK_SCRIPT="$REGION_UNLOCK_SCRIPT"
YEAHWU_UNLOCK_SCRIPT="$YEAHWU_UNLOCK_SCRIPT"
MTR_TRACE_SCRIPT="$MTR_TRACE_SCRIPT"
IABC_SPEEDTEST_SCRIPT="$IABC_SPEEDTEST_SCRIPT"
FUSION_TEST_SCRIPT="$FUSION_TEST_SCRIPT"
GB5_SCRIPT="$GB5_SCRIPT"
REINSTALL_SCRIPT="$REINSTALL_SCRIPT"
BESTTRACE_SCRIPT="$BESTTRACE_SCRIPT"
SUPERSPEED_SCRIPT="$SUPERSPEED_SCRIPT"
LIMIT_SHUTDOWN_SCRIPT="$LIMIT_SHUTDOWN_SCRIPT"
EOF
  fi

  # shellcheck disable=SC1090
  . "$UA_BOX_CONFIG"
}

log_action() {
  local message="$*"
  mkdir -p "$UA_BOX_LOG_DIR"
  # 日志超过 5MB 自动轮转，保留最近一份
  if [ -f "$UA_BOX_LOG_FILE" ] && [ "$(wc -c < "$UA_BOX_LOG_FILE" 2>/dev/null || echo 0)" -gt 5242880 ]; then
    mv "$UA_BOX_LOG_FILE" "${UA_BOX_LOG_FILE}.1"
  fi
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')" "$message" >> "$UA_BOX_LOG_FILE"
}

confirm_danger() {
  local message="$1"
  local target="$2"

  echo -e "${gl_hong}危险操作:${gl_bai} $message"
  echo "影响范围: 可能修改系统配置、服务状态、数据或网络访问策略。"
  [ -n "$target" ] && echo "对象/命令: $target"
  read -r -p "请输入 yes/y 确认继续，输入 n 取消: " answer
  case "$answer" in
    yes|y|Y) return 0 ;;
    n|N|no|No|NO|"") echo "已取消。"; return 1 ;;
    *) echo "输入未确认，已取消。"; return 1 ;;
  esac
}

backup_self() {
  local src
  local dst

  src="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  dst="$UA_BOX_BACKUP_DIR/ua-box-$(date '+%Y%m%d-%H%M%S').bak"
  cp "$src" "$dst"
  log_action "backup_self $dst"
  echo "已备份到: $dst"
}

create_local_links() {
  local srcTarget
  srcTarget="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  local target="/usr/local/bin/ua"

  chmod +x "$srcTarget"
  ln -sf "$srcTarget" /usr/local/bin/ua-box

  if [ -e "$target" ] && [ ! -L "$target" ]; then
    echo "检测到 $target 已存在且不是符号链接。"
    echo "为避免覆盖已有命令，未自动设置 ua。"
    echo "确认要替换时，可先备份原文件，再执行：ln -sf $srcTarget $target"
  else
    ln -sf "$srcTarget" "$target"
    echo "已设置/修复全局命令: ua"
  fi
  echo "备用命令仍可使用: ua-box"
}

update_self() {
  local src tmp update_url up_choice update_git

  # 1. 检测是否为 Git 仓库并提示通过 Git 更新
  if [ -d "$UA_BOX_HOME/.git" ]; then
    echo -e "检测到当前项目是通过 ${gl_lv}Git 克隆${gl_bai} 安装的。"
    read -r -e -p "是否通过 Git 拉取最新代码进行更新？[Y/n]: " update_git
    update_git="${update_git:-y}"
    if [ "$update_git" = "y" ] || [ "$update_git" = "Y" ]; then
      echo "开始通过 Git 更新..."
      log_action "update via git pull"
      backup_self || return 1
      if (cd "$UA_BOX_HOME" && git pull); then
        create_local_links >/dev/null 2>&1 || true
        echo -e "${gl_lv}Git 更新成功！${gl_bai}"
      else
        echo -e "${gl_hong}Git 拉取失败，请检查网络或本地修改。${gl_bai}"
      fi
      return 0
    fi
  fi

  # 2. 交互式选择更新源（包含手动输入选项）
  echo "请选择更新源："
  echo -e "1) 使用配置的 URL 进行更新 [ ${gl_lv}${UA_BOX_UPDATE_URL:-未配置}${gl_bai} ]"
  echo "2) 手动输入自定义 URL 进行更新"
  echo "0) 取消"
  read -r -e -p "请输入选择 (0-2): " up_choice
  [ -z "$up_choice" ] && return 0

  case "$up_choice" in
    1)
      if [ -z "$UA_BOX_UPDATE_URL" ]; then
        echo -e "${gl_hong}错误: 配置文件中未设置 UA_BOX_UPDATE_URL。${gl_bai}"
        return 1
      fi
      update_url="$UA_BOX_UPDATE_URL"
      ;;
    2)
      read -r -e -p "请输入更新脚本的完整 URL: " update_url
      if [ -z "$update_url" ]; then
        echo "URL 不能为空。"
        return 1
      fi
      ;;
    *)
      return 0
      ;;
  esac

  # 3. 下载并覆盖更新
  src="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  tmp="$UA_BOX_TMP_DIR/ua-box-update.$$"
  backup_self || return 1
  echo "正在从 $update_url 下载最新版本..."
  download_to "$update_url" "$tmp" || return 1
  bash -n "$tmp" || {
    echo "下载的新脚本语法校验失败，已取消更新。"
    rm -f "$tmp"
    return 1
  }
  cp "$tmp" "$src"
  chmod +x "$src"
  rm -f "$tmp"
  log_action "update_self from $update_url"
  create_local_links >/dev/null 2>&1 || true
  echo -e "${gl_lv}UA Box 已更新成功！${gl_bai}"
}

init_ua_box

pause() {
  echo ""
  echo -e "${gl_lv}操作完成${gl_bai}"
  read -n 1 -s -r -p "按任意键继续..." || return 0
  echo ""
}

need_root() {
  if [ "$(id -u)" -ne 0 ]; then
    echo -e "${gl_hong}错误:${gl_bai} 此操作需要 root 权限。"
    echo "请使用 root 用户或 sudo 运行。"
    return 1
  fi
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

is_pkg_installed() {
  local pkg="$1"
  if has_cmd dpkg; then
    dpkg -s "$pkg" 2>/dev/null | grep -q "Status: install ok installed" && return 0
  elif has_cmd rpm; then
    rpm -q "$pkg" >/dev/null 2>&1 && return 0
  elif has_cmd apk; then
    apk info -e "$pkg" >/dev/null 2>&1 && return 0
  fi
  has_cmd "$pkg" && return 0
  return 1
}

is_port_taken() {
  local port="$1"
  if has_cmd ss; then
    ss -tlnp 2>/dev/null | grep -Eq ":${port}\s"
  elif has_cmd netstat; then
    netstat -tlnp 2>/dev/null | grep -Eq ":${port}\s"
  else
    lsof -i :"$port" >/dev/null 2>&1
  fi
}

list_has_word() {
  local needle="$1"
  local list="$2"
  local item

  # shellcheck disable=SC2086
  for item in $list; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

list_add_words() {
  local list="$1"
  shift

  local item
  for item in "$@"; do
    [ -z "$item" ] && continue
    list_has_word "$item" "$list" || list="${list:+$list }$item"
  done
  printf '%s\n' "$list"
}

list_remove_words() {
  local list="$1"
  shift

  local result item remove word
  result=""
  # shellcheck disable=SC2086
  for item in $list; do
    remove=0
    for word in "$@"; do
      [ "$item" = "$word" ] && remove=1
    done
    [ "$remove" -eq 0 ] && result="${result:+$result }$item"
  done
  printf '%s\n' "$result"
}

config_set_var() {
  local var="$1"
  local value="$2"
  local tmp escaped

  escaped="$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  tmp="$UA_BOX_TMP_DIR/ua-box-config.$$"
  awk -v var="$var" -v value="$escaped" '
    BEGIN { found=0 }
    $0 ~ "^" var "=" {
      print var "=\"" value "\"";
      found=1;
      next;
    }
    { print }
    END {
      if (!found) print var "=\"" value "\"";
    }
  ' "$UA_BOX_CONFIG" > "$tmp" && mv "$tmp" "$UA_BOX_CONFIG"
  # shellcheck disable=SC1090
  . "$UA_BOX_CONFIG"
}

pkg_manager() {
  if [ -n "$_UA_PKG_MANAGER" ]; then
    echo "$_UA_PKG_MANAGER"
    return
  fi

  local pm=""
  if has_cmd apt; then
    pm="apt"
  elif has_cmd dnf; then
    pm="dnf"
  elif has_cmd yum; then
    pm="yum"
  elif has_cmd apk; then
    pm="apk"
  elif has_cmd pacman; then
    pm="pacman"
  elif has_cmd zypper; then
    pm="zypper"
  elif has_cmd opkg; then
    pm="opkg"
  fi

  _UA_PKG_MANAGER="$pm"
  echo "$pm"
}

install_pkg() {
  if [ "$#" -eq 0 ]; then
    echo "未提供软件包参数。"
    return 1
  fi

  need_root || return 1
  log_action "install_pkg $*"

  local pm
  pm="$(pkg_manager)"
  if [ -z "$pm" ]; then
    echo -e "${gl_hong}未知包管理器，无法安装。${gl_bai}"
    return 1
  fi

  # 过滤出未安装的包
  local pkgs_to_install=""
  local pkg
  for pkg in "$@"; do
    if ! is_pkg_installed "$pkg"; then
      pkgs_to_install="$pkgs_to_install $pkg"
    fi
  done

  if [ -z "$pkgs_to_install" ]; then
    echo "所有请求的软件包已安装。"
    return 0
  fi

  case "$pm" in
    apt)
      local _apt_interval="${UA_APT_UPDATE_INTERVAL:-60}"
      if [ ! -f /tmp/.ua-apt-updated ] || \
         [ -n "$(find /tmp/.ua-apt-updated -mmin +"$_apt_interval" 2>/dev/null)" ]; then
        apt update -y
        touch /tmp/.ua-apt-updated
      fi
      apt install -y "$@"
      ;;
    dnf)
      dnf install -y "$@"
      ;;
    yum)
      yum install -y epel-release
      yum install -y "$@"
      ;;
    apk)
      apk update
      apk add "$@"
      ;;
    pacman)
      pacman -Syu --noconfirm
      pacman -S --noconfirm "$@"
      ;;
    zypper)
      zypper refresh
      zypper install -y "$@"
      ;;
    opkg)
      opkg update
      opkg install "$@"
      ;;
  esac
}

remove_pkg() {
  if [ "$#" -eq 0 ]; then
    echo "未提供软件包参数。"
    return 1
  fi

  need_root || return 1
  log_action "remove_pkg $*"

  local pm orphans
  pm="$(pkg_manager)"
  case "$pm" in
    apt) apt purge -y "$@" ;;
    dnf) dnf remove -y "$@" ;;
    yum) yum remove -y "$@" ;;
    apk) apk del "$@" ;;
    pacman) pacman -Rns --noconfirm "$@" ;;
    zypper) zypper remove -y "$@" ;;
    opkg) opkg remove "$@" ;;
    *) echo -e "${gl_hong}未知包管理器，无法卸载。${gl_bai}"; return 1 ;;
  esac
}

svc() {
  local action="$1"
  local name="$2"

  if [ -z "$name" ]; then
    echo "未提供服务名。"
    return 1
  fi

  if has_cmd systemctl; then
    systemctl "$action" "$name"
  elif has_cmd service; then
    service "$name" "$action"
  else
    echo "当前系统未找到 systemctl/service。"
    return 1
  fi
}

svc_status_short() {
  local name="$1"

  if has_cmd systemctl; then
    if systemctl is-active --quiet "$name" 2>/dev/null; then
      echo -e "${gl_lv}运行中${gl_bai}"
    elif systemctl status "$name" >/dev/null 2>&1; then
      echo -e "${gl_huang}未运行${gl_bai}"
    else
      echo -e "${gl_hui}未安装${gl_bai}"
    fi
  elif has_cmd service; then
    if service "$name" status >/dev/null 2>&1; then
      echo -e "${gl_lv}运行中${gl_bai}"
    else
      echo -e "${gl_huang}未知/未运行${gl_bai}"
    fi
  else
    echo -e "${gl_hui}无法检测${gl_bai}"
  fi
}

download_to() {
  local url="$1"
  local output="$2"

  log_action "download $url -> $output"

  if has_cmd curl; then
    curl --connect-timeout 10 --max-time 60 -fsSL "$url" -o "$output"
  elif has_cmd wget; then
    wget --timeout=15 -qO "$output" "$url"
  else
    echo "未找到 curl/wget，先安装基础下载工具。"
    install_pkg curl wget || return 1
    curl --connect-timeout 10 --max-time 60 -fsSL "$url" -o "$output"
  fi
}

download_first_to() {
  local output="$1"
  shift

  local url
  for url in "$@"; do
    [ -z "$url" ] && continue
    echo "尝试下载: $url"
    if download_to "$url" "$output"; then
      echo "$url" > "${output}.source"
      return 0
    fi
    echo "下载失败，切换备用源。"
  done

  echo "所有下载源都不可用。"
  return 1
}

country_code() {
  if has_cmd curl; then
    curl -fsS --max-time 3 https://ipinfo.io/country 2>/dev/null
  elif has_cmd wget; then
    wget -qO- --timeout=3 https://ipinfo.io/country 2>/dev/null
  fi
}

human_uptime() {
  awk -F. '{
    d=int($1/86400);
    h=int(($1%86400)/3600);
    m=int(($1%3600)/60);
    if (d>0) printf "%d天 ", d;
    if (h>0) printf "%d时 ", h;
    printf "%d分\n", m
  }' /proc/uptime 2>/dev/null
}

public_ip() {
  if has_cmd curl; then
    curl -fsS --max-time 3 https://ipinfo.io/ip 2>/dev/null
  elif has_cmd wget; then
    wget -qO- --timeout=3 https://ipinfo.io/ip 2>/dev/null
  fi
}

get_display_ip() {
  if [ -z "${_UA_DISPLAY_IP:-}" ]; then
    _UA_DISPLAY_IP="$(public_ip)"
    [ -z "$_UA_DISPLAY_IP" ] && _UA_DISPLAY_IP="$(local_ip)"
    [ -z "$_UA_DISPLAY_IP" ] && _UA_DISPLAY_IP="服务器IP"
  fi
  echo "$_UA_DISPLAY_IP"
}

public_ipv6() {
  if has_cmd curl; then
    curl -6 -fsS --max-time 3 https://api64.ipify.org 2>/dev/null || curl -6 -fsS --max-time 3 https://ip.sb 2>/dev/null
  elif has_cmd wget; then
    wget -6 -qO- --timeout=3 https://api64.ipify.org 2>/dev/null || wget -6 -qO- --timeout=3 https://ip.sb 2>/dev/null
  fi
}

get_virt() {
  local virt="未知"
  if has_cmd systemd-detect-virt; then
    virt="$(systemd-detect-virt 2>/dev/null)"
    case "$virt" in
      none) virt="物理机" ;;
      kvm) virt="KVM" ;;
      qemu) virt="QEMU" ;;
      vmware) virt="VMware" ;;
      microsoft) virt="Hyper-V" ;;
      oracle) virt="VirtualBox" ;;
      xen) virt="Xen" ;;
      openvz) virt="OpenVZ" ;;
      lxc) virt="LXC" ;;
      lxc-libvirt) virt="LXC (Libvirt)" ;;
      docker) virt="Docker" ;;
      wsl) virt="WSL" ;;
      google|gce) virt="Google Cloud (GCP)" ;;
      amazon|aws) virt="Amazon EC2 (AWS)" ;;
      *) virt="$(echo "$virt" | tr '[:lower:]' '[:upper:]')" ;;
    esac
  elif [ -f /proc/user_beancounters ]; then
    virt="OpenVZ"
  elif [ -d /proc/xen ] || grep -q "control_d" /proc/xen/capabilities 2>/dev/null; then
    virt="Xen"
  elif grep -Eqi "qemu|kvm" /sys/class/dmi/id/product_name 2>/dev/null || grep -Eqi "qemu|kvm" /sys/class/dmi/id/sys_vendor 2>/dev/null; then
    virt="KVM"
  elif [ -d /sys/module/hyperv ]; then
    virt="Hyper-V"
  elif grep -qi "vmware" /proc/cpuinfo 2>/dev/null; then
    virt="VMware"
  fi
  echo "$virt" | tr '[:lower:]' '[:upper:]'
}

local_ip() {
  ip route get 8.8.8.8 2>/dev/null | awk '/src/ {for (i=1;i<=NF;i++) if ($i=="src") {print $(i+1); exit}}'
}

net_total() {
  awk '
    $1 ~ /^[a-zA-Z0-9_.:-]+:$/ && $1 !~ /^lo:/ {
      rx += $2;
      tx += $10
    }
    END {
      printf "%.2fG / %.2fG", rx/1024/1024/1024, tx/1024/1024/1024
    }
  ' /proc/net/dev 2>/dev/null
}

cpu_usage() {
  awk '/^cpu / {u=$2+$4; t=$2+$4+$5; print u, t}' /proc/stat | {
    read -r u1 t1
    sleep 0.2
    awk '/^cpu / {u=$2+$4; t=$2+$4+$5; print u, t}' /proc/stat | {
      read -r u2 t2
      awk -v u1="$u1" -v t1="$t1" -v u2="$u2" -v t2="$t2" 'BEGIN {
        if (t2 == t1) print "0";
        else printf "%.0f", (u2-u1)*100/(t2-t1)
      }'
    }
  }
}

system_info() {
  clear
  local hostname os kernel arch cpu_model cores cpu_freq cpu_percent load mem swap disk uptime dns ipv4 ipv6 wan_ipv4 wan_ipv6 tcp_cc qdisc net_io now virt country

  hostname="$(hostname 2>/dev/null)"
  virt="$(get_virt)"
  os="$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME")"
  kernel="$(uname -r)"
  arch="$(uname -m)"
  cpu_model="$(awk -F': ' '/model name|Hardware/ {print $2; exit}' /proc/cpuinfo 2>/dev/null)"
  cores="$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc 2>/dev/null)"
  cpu_freq="$(awk -F': ' '/cpu MHz/ {printf "%.1f GHz", $2/1000; exit}' /proc/cpuinfo 2>/dev/null)"
  cpu_percent="$(cpu_usage)"
  load="$(awk '{print $1" "$2" "$3}' /proc/loadavg 2>/dev/null)"
  mem="$(free -m | awk '/^Mem:/ {printf "%dM/%dM (%d%%)", $3, $2, $3*100/$2}')"
  swap="$(free -m | awk '/^Swap:/ {if ($2==0) printf "0M/0M (0%%)"; else printf "%dM/%dM (%d%%)", $3, $2, $3*100/$2}')"
  disk="$(df -h / | awk 'NR==2 {print $3"/"$2" ("$5")"}')"
  uptime="$(human_uptime)"
  dns="$(awk '/^nameserver/ {printf "%s ", $2}' /etc/resolv.conf 2>/dev/null)"
  ipv4="$(local_ip)"
