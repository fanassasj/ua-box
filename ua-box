install_docker() {
  need_root || return 1

  if has_cmd docker; then
    echo "Docker 已安装。"
    docker --version
    return 0
  fi

  local target="$UA_BOX_TMP_DIR/get-docker.sh"
  local sources source args country

  sources="${DOCKER_INSTALL_SCRIPTS:-$DOCKER_INSTALL_SCRIPT}"
  # shellcheck disable=SC2086
  download_first_to "$target" $sources || return 1
  chmod +x "$target"
  source="$(cat "${target}.source" 2>/dev/null)"
  country="$(country_code)"

  args=""
  case "$source" in
    *get.docker.com*|*docker/docker-install*)
      [ "$country" = "CN" ] && args="--mirror Aliyun"
      ;;
  esac

  log_action "install Docker from $source $args"
  # shellcheck disable=SC2086
  sh "$target" $args

  if has_cmd systemctl; then
    systemctl enable --now docker >/dev/null 2>&1 || true
  fi

  if has_cmd apt; then
    apt install -y docker-compose-plugin >/dev/null 2>&1 || true
  elif has_cmd dnf; then
    dnf install -y docker-compose-plugin >/dev/null 2>&1 || true
  elif has_cmd yum; then
    yum install -y docker-compose-plugin >/dev/null 2>&1 || true
  elif has_cmd apk; then
    apk add docker-compose >/dev/null 2>&1 || true
  fi

  if has_cmd docker; then
    echo "Docker 安装完成。"
    docker --version
    if docker compose version >/dev/null 2>&1; then
      docker compose version
    else
      echo -e "${gl_huang}提示: docker compose 插件未安装，可手动执行: ua install docker-compose-plugin${gl_bai}"
    fi
  else
    echo "Docker 安装后仍未检测到 docker 命令，请查看上方安装输出。"
    return 1
  fi
}

docker_require() {
  if ! has_cmd docker; then
    echo "未找到 Docker，请先安装 Docker。"
    return 1
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "Docker 已安装但 daemon 未运行，请执行: systemctl start docker"
    return 1
  fi
}

docker_compose_run() {
  local action="$1"
  local compose_dir="$2"

  if [ -z "$compose_dir" ]; then
    compose_dir="."
  fi

  if [ ! -d "$compose_dir" ]; then
    echo "目录不存在: $compose_dir"
    return 1
  fi

  local _compose_extra=""
  [ "$action" = "up" ] && _compose_extra="-d"

  if docker compose version >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    (cd "$compose_dir" && docker compose "$action" $_compose_extra)
  elif has_cmd docker-compose; then
    # shellcheck disable=SC2086
    (cd "$compose_dir" && docker-compose "$action" $_compose_extra)
  else
    echo "未找到 docker compose 插件或 docker-compose。"
    return 1
  fi
}

