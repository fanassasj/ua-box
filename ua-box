system_update() {
  need_root || return 1
  log_action "system update"

  local pm
  pm="$(pkg_manager)"
  echo -e "${gl_huang}正在系统更新...${gl_bai}"

  case "$pm" in
    apt)
      dpkg --configure -a 2>/dev/null || true
      apt update -y
      DEBIAN_FRONTEND=noninteractive apt full-upgrade -y
      ;;
    dnf) dnf -y update ;;
    yum) yum -y update ;;
    apk) apk update && apk upgrade ;;
    pacman) pacman -Syu --noconfirm ;;
    zypper) zypper refresh && zypper update -y ;;
    opkg) opkg update && opkg upgrade ;;
    *) echo "未知包管理器，无法系统更新。"; return 1 ;;
  esac
}

system_clean() {
  need_root || return 1
  log_action "system clean"

  local pm orphans
  pm="$(pkg_manager)"
  echo -e "${gl_huang}正在系统清理...${gl_bai}"

  case "$pm" in
    apt)
      apt autoremove --purge -y
      apt clean -y
      apt autoclean -y
      ;;
    dnf)
      dnf autoremove -y
      dnf clean all
      ;;
    yum)
      yum autoremove -y
      yum clean all
      ;;
    apk)
      apk cache clean
      ;;
    pacman)
      orphans="$(pacman -Qdtq 2>/dev/null || true)"
      if [ -n "$orphans" ]; then
        # shellcheck disable=SC2086
        pacman -Rns $orphans --noconfirm 2>/dev/null || true
      fi
      pacman -Scc --noconfirm
      ;;
    zypper)
      zypper clean --all
      ;;
    opkg)
      opkg clean
      ;;
    *) echo "未知包管理器，跳过包缓存清理。" ;;
  esac

  if has_cmd journalctl; then
    journalctl --rotate 2>/dev/null || true
    journalctl --vacuum-size=500M 2>/dev/null || true
  fi
}

system_set_shortcut() {
  local shortcut shell_rc target

  read -r -e -p "请输入启动快捷键，例 u 或 ua，输入 0 取消: " shortcut
  [ "$shortcut" = "0" ] || [ -z "$shortcut" ] && return 0

  if ! printf '%s\n' "$shortcut" | grep -Eq '^[A-Za-z_][A-Za-z0-9_-]*$'; then
    echo "快捷键只能使用字母、数字、下划线或中划线，且不能以数字开头。"
    return 1
  fi

  shell_rc="$HOME/.bashrc"
  case "${SHELL##*/}" in zsh) shell_rc="$HOME/.zshrc" ;; esac
  target="$(readlink -f "$0" 2>/dev/null || echo "$0")"

  sed -i "/# UA Box shortcut:/d" "$shell_rc" 2>/dev/null || true
  sed -i "/alias ${shortcut}=/d" "$shell_rc" 2>/dev/null || true
  printf "\n# UA Box shortcut: %s\nalias %s='%s'\n" "$shortcut" "$shortcut" "$target" >> "$shell_rc"
  log_action "set shortcut $shortcut -> $target"
  echo "快捷键已设置: $shortcut"
  echo "重新登录 Shell 或执行 source $shell_rc 后生效。"
}

system_install_python_version() {
  local version pm pkg

  need_root || return 1
  read -r -e -p "请输入 Python 版本，例 3.11 或 3.12: " version
  [ -z "$version" ] && return 1

  if ! printf '%s\n' "$version" | grep -Eq '^3\.[0-9]+([.][0-9]+)?$'; then
    echo "版本格式不正确。"
    return 1
  fi

  pm="$(pkg_manager)"
  pkg="python${version}"
  log_action "install Python $version"

  case "$pm" in
    apt)
      apt update -y
      apt install -y "$pkg" "${pkg}-venv" "${pkg}-dev" || {
        echo "包管理器未提供 $pkg。若已安装 pyenv，可改用 pyenv 安装。"
        if has_cmd pyenv; then
          read -r -e -p "是否尝试 pyenv install $version ? 输入 yes 确认: " answer
          [ "$answer" = "yes" ] && pyenv install -s "$version"
        fi
      }
      ;;
    dnf|yum) install_pkg "$pkg" ;;
    apk) install_pkg python3 py3-pip ;;
    pacman) install_pkg python ;;
    zypper) install_pkg "$pkg" ;;
    *) echo "未知包管理器，无法安装 Python。"; return 1 ;;
  esac
}

ssh_set_global_option() {
  local file="$1"
  local key="$2"
  local value="$3"
  local tmp

  tmp="$(mktemp)" || return 1
  awk -v key="$key" -v value="$value" '
    BEGIN {
      done = 0
      in_match = 0
      key_lc = tolower(key)
    }
    {
      first = tolower($1)
    }
    first == "match" {
      if (!done) {
        print key " " value
        done = 1
      }
      in_match = 1
      print
      next
    }
    !in_match && first == key_lc {
      if (!done) {
        print key " " value
        done = 1
      }
      next
    }
    !in_match && $0 ~ "^[#[:space:]]*" key "[[:space:]]" {
      if (!done) {
        print key " " value
        done = 1
      }
      next
    }
    {
      print
    }
    END {
      if (!done) {
        print key " " value
      }
    }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
  local rc=$?
  rm -f "$tmp"
  return "$rc"
}

