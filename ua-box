openlist_install() {
  need_root || return 1
  docker_require || install_docker || return 1

  if docker_container_exists openlist; then
    docker start openlist
    echo "OpenList 容器已存在并已启动。"
    return 0
  fi

  local deploy_mode port port_dav data_dir
  echo "请选择部署方式："
  echo "1) Docker Run (普通容器部署)"
  echo "2) Docker Compose (项目部署)"
  read -r -e -p "请输入选择 (1 或 2，默认 1): " deploy_mode
  deploy_mode="${deploy_mode:-1}"

  read -r -e -p "请输入 Web 端口 (5244)，回车默认 5244: " port
  port="${port:-5244}"
  read -r -e -p "请输入 WebDAV 端口 (5245，可选)，回车默认 5245: " port_dav
  port_dav="${port_dav:-5245}"

  for p in "$port" "$port_dav"; do
    if ! printf '%s\n' "$p" | grep -Eq '^[0-9]+$'; then
      echo "端口必须是纯数字。"
      return 1
    fi
    if is_port_taken "$p"; then
      echo -e "${gl_hong}错误:${gl_bai} 端口 $p 已被占用，请先释放端口或指定其他映射端口。"
      return 1
    fi
  done

  data_dir="/root/openlist"
  mkdir -p "$data_dir/data"

  if [ "$deploy_mode" = "2" ]; then
    if ! docker compose version >/dev/null 2>&1 && ! has_cmd docker-compose; then
      echo "未检测到 docker compose，将自动尝试安装..."
      install_pkg docker-compose-plugin || install_pkg docker-compose || { echo "安装 docker-compose 失败。"; return 1; }
    fi

    cat > "$data_dir/docker-compose.yml" <<EOF
version: '3.3'
services:
  openlist:
    image: openlistteam/openlist:latest
    container_name: openlist
    restart: always
    ports:
      - "$port:5244"
      - "$port_dav:5245"
    volumes:
      - ./data:/opt/openlist/data
    environment:
      - UMASK=022
      - TZ=Asia/Shanghai
    user: "0:0"
EOF

    log_action "install OpenList (Docker Compose, port=$port, port_dav=$port_dav)"
    local compose_cmd="docker compose"
    if ! docker compose version >/dev/null 2>&1; then
      compose_cmd="docker-compose"
    fi
    (cd "$data_dir" && $compose_cmd up -d)
    echo "OpenList 已使用 Docker Compose 部署。"
  else
    log_action "install OpenList (Docker Run, port=$port, port_dav=$port_dav)"
    docker run -d \
      --name openlist \
      --restart always \
      -p "$port":5244 \
      -p "$port_dav":5245 \
      -v "$data_dir/data":/opt/openlist/data \
      -e UMASK=022 \
      -e TZ=Asia/Shanghai \
      --user "0:0" \
      openlistteam/openlist:latest
    echo "OpenList 已使用 Docker Run 部署。"
  fi

  echo "正在等待容器启动并获取初始密码..."
  sleep 6
  local init_pwd
  init_pwd="$(docker logs openlist 2>&1 | grep "Successfully created the admin user and the password is" | awk -F'is ' '{print $2}' | tr -d '\r\n ')"
  
  if [ -z "$init_pwd" ]; then
    init_pwd="$(docker exec -i openlist ./openlist admin random 2>/dev/null | grep "password:" | awk '{print $2}' | tr -d '\r\n ')"
  fi
  if [ -z "$init_pwd" ]; then
    init_pwd="$(docker exec -i openlist ./alist admin random 2>/dev/null | grep "password:" | awk '{print $2}' | tr -d '\r\n ')"
  fi

  echo "OpenList 已部署。访问: http://$(get_display_ip):$port"
  if [ -n "$init_pwd" ]; then
    echo "管理员初始密码: $init_pwd"
    echo "请尽快登录后台修改密码。"
  else
    echo "提示: 未能在日志中截获初始密码，您可以运行以下命令手动获取/重置密码："
    echo "  docker exec -it openlist ./openlist admin random"
  fi
}

