  if ! printf '%s\n' "$length" | grep -Eq '^[0-9]+$' || [ "$length" -lt 8 ]; then
    echo "密码长度必须是大于等于 8 的数字。"
    return 1
  fi

  username="${username:-user$(date +%m%d%H%M)}"
  if has_cmd openssl; then
    password="$(openssl rand -base64 48 | tr -dc 'A-Za-z0-9_@#%+=' | head -c "$length")"
  else
    password="$(tr -dc 'A-Za-z0-9_@#%+=' </dev/urandom | head -c "$length")"
  fi

  echo "用户名: $username"
  echo "密码:   $password"
}

